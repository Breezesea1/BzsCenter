############################################
# VS Code
############################################
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

############################################
# NuGet
############################################
# packages/ (only if you still use packages.config style)
packages/
# NuGet v3 cache shouldn't be in repo, but included here for completeness
# (usually not inside repo anyway)
# .nuget/NuGet.exe
# project.lock.json (old)
project.lock.json
# NuGet artifacts
*.nupkg
*.snupkg

############################################
# dotnet tools / artifacts
############################################
# Local tool manifest cache or tool outputs
.dotnet/
.aspire/
artifacts/
deploy/.env
deploy/README.md
production.env
# dotnet user secrets - do NOT commit secrets
**/secrets.json
**/*.secrets.json

############################################
# ASP.NET / IIS / Kestrel
############################################
# Local IIS Express
**/.vs/config/applicationhost.config
# HTTPS dev cert (don’t commit)
*.pfx
*.p12

############################################
# Node / Frontend (if you have SPA/Blazor WASM tooling etc.)
############################################
node_modules/
nodemodules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
**/dist/
**/.parcel-cache/
**/.vite/

############################################
# Docker / Compose local volumes (only if inside repo)
############################################
**/docker-data/
**/data/
**/.docker/

############################################
# Azure / AWS / other tooling
############################################
# Azure Functions local settings
local.settings.json
# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log

############################################

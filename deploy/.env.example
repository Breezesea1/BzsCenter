# -------------------------------
# Project and image settings
# -------------------------------
COMPOSE_PROJECT_NAME=bzscenter

GHCR_IMAGE_PREFIX=ghcr.io/breezesea1
IMAGE_TAG=latest
IDP_BIND_HOST=127.0.0.1
IDP_HTTP_PORT=8080

# -------------------------------
# Runtime
# -------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
IdpIssuer=https://idp.example.com

# -------------------------------
# Bootstrap admin account
# -------------------------------
Identity__Admin__UserName=admin
Identity__Admin__Password=replace-with-a-long-random-admin-password

# -------------------------------
# Database
# -------------------------------
# Primary example: use an external PostgreSQL instance.
# If you want the bundled infra overlay instead, use:
#   Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
ConnectionStrings__DefaultConnection=Host=your-postgres-host;Port=5432;Database=bzscenter;Username=bzscenter;Password=replace-with-a-strong-postgres-password;SSL Mode=Prefer;Trust Server Certificate=true

# Only needed when you use deploy/docker-compose.with-infra.yml
POSTGRES_DB=bzscenter
POSTGRES_USER=bzscenter
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# -------------------------------
# Cache
# -------------------------------
CacheOptions__CacheType=Redis

# Primary example: use an external Redis instance.
# If you want the bundled infra overlay instead, set this to: redis:6379
# If your Redis uses ACL/auth, prefer user/password form like below.
ConnectionStrings__redis=your-redis-host:6379,user=default,password=replace-with-a-strong-redis-password,abortConnect=false

# -------------------------------
# ASP.NET Core Data Protection
# -------------------------------
DataProtection__ApplicationName=BzsCenter.Idp
DataProtection__StorageDirectory=/var/lib/bzscenter/idp-dpkeys
DataProtection__KeyLifetimeDays=90

# -------------------------------
# OIDC production certificates
# -------------------------------
Oidc__SigningCertificatePath__0=/certs/oidc-signing.pfx
Oidc__SigningCertificatePassword__0=replace-with-signing-cert-password
Oidc__EncryptionCertificatePath__0=/certs/oidc-encryption.pfx
Oidc__EncryptionCertificatePassword__0=replace-with-encryption-cert-password

# -------------------------------
# Reverse proxy / forwarded headers
# Leave blank unless you need to pin trusted proxies/networks.
# -------------------------------
ForwardedHeaders__KnownProxies__0=
ForwardedHeaders__KnownIpNetworks__0=

# -------------------------------
# GitHub external login
# Configure a GitHub OAuth app callback URL that ends with /signin-github
# -------------------------------
Authentication__GitHub__ClientId=replace-with-github-client-id
Authentication__GitHub__ClientSecret=replace-with-github-client-secret
Authentication__GitHub__CallbackPath=/signin-github

# -------------------------------
# Host paths
# Create these directories before first boot.
# -------------------------------
CERTS_PATH=/opt/bzscenter/certs
DATA_PROTECTION_PATH=/opt/bzscenter/data-protection

# Only needed when you use deploy/docker-compose.with-infra.yml
POSTGRES_DATA_PATH=/opt/bzscenter/postgres
REDIS_DATA_PATH=/opt/bzscenter/redis

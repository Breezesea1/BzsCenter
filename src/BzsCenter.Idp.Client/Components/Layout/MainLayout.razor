@using System.Globalization
@using System.Text
@using Microsoft.Extensions.Localization
@inherits LayoutComponentBase
@inject IStringLocalizerFactory LocalizerFactory
@inject NavigationManager NavigationManager

<div class="layout-shell">
    <aside class="sidebar-panel @(_isSidebarCollapsed ? "collapsed" : string.Empty) @(_isMobileMenuOpen ? "mobile-open" : string.Empty)">
        <NavMenu IsCollapsed="_isSidebarCollapsed"
                 IsMobileOpen="_isMobileMenuOpen"
                 OnToggleCollapse="ToggleSidebarCollapse"
                 OnCloseMobile="CloseMobileSidebar"/>
    </aside>

    <div class="layout-backdrop @(_isMobileMenuOpen ? "show" : string.Empty)" @onclick="CloseMobileSidebar"></div>

    <main class="layout-main">
        <header class="layout-topbar">
            <div class="topbar-left">
                <button class="topbar-icon-btn mobile-only"
                        type="button"
                        aria-label="Open navigation menu"
                        aria-expanded="@_isMobileMenuOpen.ToString().ToLowerInvariant()"
                        @onclick="ToggleMobileMenu">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 6h16M4 12h16M4 18h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </button>

                <span class="topbar-title">@CurrentPageTitle</span>
            </div>

            <Preferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName"/>
        </header>

        <article class="layout-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isMobileMenuOpen;
    private bool _isSidebarCollapsed;

    [CascadingParameter]
    private RouteData? CurrentRouteData { get; set; }

    private string CurrentCultureName =>
        CultureInfo.CurrentUICulture.Name;

    private string CurrentThemeName =>
        "system";

    private string CurrentPageTitle =>
        ResolveCurrentPageTitle();

    private void ToggleMobileMenu()
    {
        _isMobileMenuOpen = !_isMobileMenuOpen;
    }

    private void CloseMobileSidebar()
    {
        _isMobileMenuOpen = false;
    }

    private void ToggleSidebarCollapse()
    {
        _isSidebarCollapsed = !_isSidebarCollapsed;
    }

    private string ResolveCurrentPageTitle()
    {
        var pageType = CurrentRouteData?.PageType ?? ResolveSpecialPageType();
        if (pageType is null)
        {
            return "Dashboard";
        }

        var localized = LocalizerFactory.Create(pageType)["PageTitle"];
        if (!localized.ResourceNotFound && !string.IsNullOrWhiteSpace(localized.Value))
        {
            return localized.Value;
        }

        return HumanizePageName(pageType.Name);
    }

    private Type? ResolveSpecialPageType()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var path = relativePath.Split('?', '#')[0].Trim('/');

        return path switch
        {
            "not-found" => typeof(BzsCenter.Idp.Client.Components.Pages.NotFound),
            _ => null,
        };
    }

    private static string HumanizePageName(string pageName)
    {
        if (string.IsNullOrWhiteSpace(pageName))
        {
            return "Dashboard";
        }

        var normalized = pageName.EndsWith("Page", StringComparison.Ordinal)
            ? pageName[..^4]
            : pageName;

        var builder = new StringBuilder(normalized.Length + 8);
        for (var i = 0; i < normalized.Length; i++)
        {
            var current = normalized[i];
            if (i > 0 && char.IsUpper(current) && !char.IsUpper(normalized[i - 1]))
            {
                builder.Append(' ');
            }

            builder.Append(current);
        }

        return builder.ToString();
    }
}

@implements IAsyncDisposable
@using System.Security.Claims
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@rendermode InteractiveServer
@inject IStringLocalizer<NavMenu> L
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<nav class="menu-shell @GetStateClass()" aria-label="@L["PrimaryNavigation"]">
    <header class="menu-header">
        <SidebarBrand Href=""
                      Mark="B"
                      Text="BzsCenter"
                      OnClick="CloseMobileAsync" />

        <button class="menu-close"
                type="button"
                aria-label="@L["CloseNavigation"]"
                @onclick="CloseMobileAsync">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round"/>
            </svg>
        </button>
    </header>

    <div class="menu-body">
        <SidebarNavItem Href=""
                        Label="@L["Home"]"
                        Match="NavLinkMatch.All"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M3 11.5 12 4l9 7.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M5 10.5V20h14v-9.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>

        <AuthorizeView>
            <NotAuthorized>
                <SidebarNavItem Href="/login"
                                Label="@L["Login"]"
                                UseAnchor="true"
                                DisableEnhancedNavigation="true"
                                OnClick="CloseMobileAsync">
                    <Icon>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M4 20c1.7-3.3 4.4-5 8-5s6.3 1.7 8 5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round"/>
                        </svg>
                    </Icon>
                </SidebarNavItem>
            </NotAuthorized>
        </AuthorizeView>

        <SidebarNavItem Href="/admin/users"
                        Label="@L["Users"]"
                        Match="NavLinkMatch.All"
                        DisableEnhancedNavigation="true"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>

        <SidebarNavItem Href="/admin/clients"
                        Label="@L["Clients"]"
                        Match="NavLinkMatch.All"
                        DisableEnhancedNavigation="true"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 21h8M12 17v4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>
    </div>

    <div class="menu-divider"></div>

    <footer class="menu-footer">
        <AuthorizeView Context="authContext">
            <Authorized>
                <div class="sidebar-user-menu" @ref="_userMenuRef">
                    <SidebarUserMenu Avatar="@GetUserAvatar(authContext.User)"
                                     Name="@GetUserName(authContext.User)"
                                     SecondaryText="@GetUserSecondaryText(authContext.User)"
                                     AvatarButtonAriaLabel="@L["OpenUserMenu"]"
                                     AvatarControlsId="@_userPanelId"
                                     AvatarExpanded="@_isUserPanelOpen"
                                     OnAvatarClick="ToggleUserPanelAsync" />

                    @if (_isUserPanelOpen)
                    {
                        <div id="@_userPanelId"
                             class="sidebar-user-panel"
                             aria-label="@L["QuickActions"]"
                             @onclick:stopPropagation="true">
                            <a class="sidebar-user-panel__action sidebar-user-panel__action--destructive"
                               href="@BuildLogoutUrl()"
                               data-enhance-nav="false"
                               @onclick="CloseUserPanelAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M15 3h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M10 17l5-5-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M15 12H3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                                <span>@L["LogOut"]</span>
                            </a>
                        </div>
                    }
                </div>
            </Authorized>
            <NotAuthorized>
                <SidebarUserMenu Avatar="G"
                                 Name="Guest"
                                 SecondaryText="Sign in to continue" />
            </NotAuthorized>
        </AuthorizeView>
    </footer>
</nav>

@code {
    private readonly string _userPanelId = $"sidebar-user-panel-{Guid.NewGuid():N}";
    private ElementReference _userMenuRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<NavMenu>? _dotNetRef;
    private bool _isUserPanelOpen;

    [Parameter] public bool IsMobileOpen { get; set; }
    [Parameter] public EventCallback OnCloseMobile { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/sidebar-user-panel.js");
            await _module.InvokeVoidAsync("init", _userMenuRef, _dotNetRef);
        }
    }

    private string GetStateClass()
    {
        var state = string.Empty;
        if (IsMobileOpen)
        {
            state = string.IsNullOrEmpty(state)
                ? "is-mobile-open"
                : $"{state} is-mobile-open";
        }

        return state;
    }

    private async Task CloseMobileAsync()
    {
        _isUserPanelOpen = false;
        await OnCloseMobile.InvokeAsync();
    }

    [JSInvokable]
    public void CloseUserPanel()
    {
        if (_isUserPanelOpen)
        {
            _isUserPanelOpen = false;
            StateHasChanged();
        }
    }

    private Task CloseUserPanelAsync()
    {
        _isUserPanelOpen = false;
        return Task.CompletedTask;
    }

    private Task ToggleUserPanelAsync()
    {
        _isUserPanelOpen = !_isUserPanelOpen;
        return Task.CompletedTask;
    }

    private string BuildLogoutUrl()
    {
        var current = new Uri(NavigationManager.Uri, UriKind.Absolute);
        var returnUrl = string.IsNullOrWhiteSpace(current.PathAndQuery)
            ? "/"
            : $"{current.PathAndQuery}{current.Fragment}";

        return QueryHelpers.AddQueryString("/logout", new Dictionary<string, string?>
        {
            ["returnUrl"] = returnUrl,
        });
    }

    private static string GetUserAvatar(ClaimsPrincipal user)
    {
        var seed = GetUserName(user);
        return string.IsNullOrWhiteSpace(seed)
            ? "U"
            : seed[..1].ToUpperInvariant();
    }

    private static string GetUserName(ClaimsPrincipal user)
    {
        return user.Identity?.Name
            ?? GetClaimValue(user, ClaimTypes.Name)
            ?? GetClaimValue(user, "name")
            ?? GetClaimValue(user, ClaimTypes.Email)
            ?? GetClaimValue(user, "email")
            ?? "Authenticated user";
    }

    private static string GetUserSecondaryText(ClaimsPrincipal user)
    {
        return GetClaimValue(user, ClaimTypes.Email)
            ?? GetClaimValue(user, "email")
            ?? (user.Identity?.IsAuthenticated == true ? "Signed in" : "Not signed in");
    }

    private static string? GetClaimValue(ClaimsPrincipal user, string claimType)
    {
        return user.Claims.FirstOrDefault(claim => string.Equals(claim.Type, claimType, StringComparison.Ordinal))?.Value;
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();

        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("dispose", _userMenuRef);
            await _module.DisposeAsync();
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }
}

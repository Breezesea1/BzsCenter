@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<NavMenu> L

<nav class="menu-shell @GetStateClass()" aria-label="@L["PrimaryNavigation"]">
    <header class="menu-header">
        <a class="sidebar-brand" href="" @onclick="CloseMobileAsync">
            <span class="sidebar-brand__mark" aria-hidden="true">B</span>
            <span class="sidebar-brand__text">BzsCenter</span>
        </a>

        <button class="menu-close"
                type="button"
                aria-label="@L["CloseNavigation"]"
                @onclick="CloseMobileAsync">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round"/>
            </svg>
        </button>
    </header>

    <div class="menu-body">
        <SidebarNavItem Href=""
                        Label="@L["Home"]"
                        Match="NavLinkMatch.All"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M3 11.5 12 4l9 7.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M5 10.5V20h14v-9.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>

        <AuthorizeView>
            <NotAuthorized>
                <SidebarNavItem Href="/login"
                                Label="@L["Login"]"
                                UseAnchor="true"
                                DisableEnhancedNavigation="true"
                                OnClick="CloseMobileAsync">
                    <Icon>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M4 20c1.7-3.3 4.4-5 8-5s6.3 1.7 8 5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round"/>
                        </svg>
                    </Icon>
                </SidebarNavItem>
            </NotAuthorized>
        </AuthorizeView>

        <SidebarNavItem Href="/admin/users"
                        Label="@L["Users"]"
                        Match="NavLinkMatch.All"
                        DisableEnhancedNavigation="true"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>

        <SidebarNavItem Href="/admin/clients"
                        Label="@L["Clients"]"
                        Match="NavLinkMatch.All"
                        DisableEnhancedNavigation="true"
                        OnClick="CloseMobileAsync">
            <Icon>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 21h8M12 17v4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round"/>
                </svg>
            </Icon>
        </SidebarNavItem>
    </div>

    <div class="menu-divider"></div>

    <footer class="menu-footer">
        <AuthorizeView Context="authContext">
            <Authorized>
                <SidebarUserCard Avatar="@GetUserAvatar(authContext.User)"
                                 Name="@GetUserName(authContext.User)"
                                 SecondaryText="@GetUserSecondaryText(authContext.User)" />
            </Authorized>
            <NotAuthorized>
                <SidebarUserCard Avatar="G"
                                 Name="Guest"
                                 SecondaryText="Sign in to continue" />
            </NotAuthorized>
        </AuthorizeView>
    </footer>
</nav>

@code {
    [Parameter] public bool IsMobileOpen { get; set; }
    [Parameter] public EventCallback OnCloseMobile { get; set; }

    private string GetStateClass()
    {
        var state = string.Empty;
        if (IsMobileOpen)
        {
            state = string.IsNullOrEmpty(state)
                ? "is-mobile-open"
                : $"{state} is-mobile-open";
        }

        return state;
    }

    private async Task CloseMobileAsync()
    {
        await OnCloseMobile.InvokeAsync();
    }

    private static string GetUserAvatar(ClaimsPrincipal user)
    {
        var seed = GetUserName(user);
        return string.IsNullOrWhiteSpace(seed)
            ? "U"
            : seed[..1].ToUpperInvariant();
    }

    private static string GetUserName(ClaimsPrincipal user)
    {
        return user.Identity?.Name
            ?? GetClaimValue(user, ClaimTypes.Name)
            ?? GetClaimValue(user, "name")
            ?? GetClaimValue(user, ClaimTypes.Email)
            ?? GetClaimValue(user, "email")
            ?? "Authenticated user";
    }

    private static string GetUserSecondaryText(ClaimsPrincipal user)
    {
        return GetClaimValue(user, ClaimTypes.Email)
            ?? GetClaimValue(user, "email")
            ?? (user.Identity?.IsAuthenticated == true ? "Signed in" : "Not signed in");
    }

    private static string? GetClaimValue(ClaimsPrincipal user, string claimType)
    {
        return user.Claims.FirstOrDefault(claim => string.Equals(claim.Type, claimType, StringComparison.Ordinal))?.Value;
    }

}

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<NavMenu> L

<nav class="menu-shell @GetStateClass()" aria-label="@L["PrimaryNavigation"]">
    <header class="menu-header">
        <a class="menu-brand" href="" @onclick="CloseMobileAsync">
            <span class="brand-mark" aria-hidden="true">B</span>
            <span class="brand-text">BzsCenter</span>
        </a>

        <button class="menu-close"
                type="button"
                aria-label="@L["CloseNavigation"]"
                @onclick="CloseMobileAsync">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round"/>
            </svg>
        </button>
    </header>

    <div class="menu-body">
        <NavLink class="menu-link group hover:bg-transparent" href="" Match="NavLinkMatch.All"
                 @onclick="CloseMobileAsync">
            <span class="menu-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M3 11.5 12 4l9 7.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M5 10.5V20h14v-9.5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            <span
                class="menu-text transition-all duration-200 group-hover:translate-x-1 group-hover:font-semibold group-hover:text-lg">@L["Home"]</span>
        </NavLink>

        <a class="menu-link group hover:bg-transparent" href="/login" data-enhance-nav="false"
           @onclick="CloseMobileAsync">
            <span class="menu-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
                    <path d="M4 20c1.7-3.3 4.4-5 8-5s6.3 1.7 8 5" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round"/>
                </svg>
            </span>
            <span
                class="menu-text transition-all duration-200 group-hover:translate-x-1 group-hover:font-semibold group-hover:text-lg">@L["Login"]</span>
        </a>

   
        <NavLink class="menu-link group hover:bg-transparent" href="/admin/users" Match="NavLinkMatch.All"
                 data-enhance-nav="false" @onclick="CloseMobileAsync">
            <span class="menu-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            <span
                class="menu-text transition-all duration-200 group-hover:translate-x-1 group-hover:font-semibold group-hover:text-lg">@L["Users"]</span>
        </NavLink>

        <NavLink class="menu-link group hover:bg-transparent" href="/admin/clients" Match="NavLinkMatch.All"
                 data-enhance-nav="false" @onclick="CloseMobileAsync">
            <span class="menu-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 21h8M12 17v4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round"/>
                </svg>
            </span>
            <span
                class="menu-text transition-all duration-200 group-hover:translate-x-1 group-hover:font-semibold group-hover:text-lg">@L["Clients"]</span>
        </NavLink>
    </div>

    <div class="menu-divider"></div>

    <footer class="menu-footer">
        <div class="menu-user">
            <span class="menu-user-avatar">A</span>
            <div class="menu-user-info">
                <span class="menu-user-name">Admin</span>
                <span class="menu-user-email">admin@bzscenter.com</span>
            </div>
        </div>
    </footer>
</nav>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public bool IsMobileOpen { get; set; }
    [Parameter] public EventCallback OnToggleCollapse { get; set; }
    [Parameter] public EventCallback OnCloseMobile { get; set; }

    private string GetStateClass()
    {
        var state = IsCollapsed ? "is-collapsed" : string.Empty;
        if (IsMobileOpen)
        {
            state = string.IsNullOrEmpty(state)
                ? "is-mobile-open"
                : $"{state} is-mobile-open";
        }

        return state;
    }

    private async Task CloseMobileAsync()
    {
        await OnCloseMobile.InvokeAsync();
    }

    private async Task ToggleCollapseAsync()
    {
        await OnToggleCollapse.InvokeAsync();
    }

}

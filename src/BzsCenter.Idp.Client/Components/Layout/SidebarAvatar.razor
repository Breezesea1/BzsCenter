@if (OnClick.HasDelegate)
{
    <button type="button"
            class="@GetCssClass()"
            aria-label="@AriaLabel"
            aria-controls="@ControlsId"
            aria-expanded="@IsExpanded.ToString().ToLowerInvariant()"
            @onclick="OnClick"
            @onclick:stopPropagation="true">
        <span class="sidebar-avatar__surface" aria-hidden="true">@Value</span>
    </button>
}
else
{
    <span class="@GetCssClass()">
        <span class="sidebar-avatar__surface" aria-hidden="true">@Value</span>
    </span>
}

@code {
    [Parameter] public string AriaLabel { get; set; } = "Open user menu";
    [Parameter] public string? ControlsId { get; set; }
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;

    private string GetCssClass()
    {
        return IsExpanded ? "sidebar-avatar is-open" : "sidebar-avatar";
    }
}

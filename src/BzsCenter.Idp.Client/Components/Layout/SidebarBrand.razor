<a class="sidebar-brand" href="@Href" @onclick="OnClick">
    <span class="sidebar-brand__mark" aria-hidden="true">
        @if (!string.IsNullOrWhiteSpace(ImageSrc))
        {
            <img src="@ImageSrc" alt="" width="28" height="28" />
        }
        else
        {
            @Mark
        }
    </span>
    <span class="sidebar-brand__text">@Text</span>
</a>

@code {
    [Parameter] public string Href { get; set; } = string.Empty;
    [Parameter] public string? ImageSrc { get; set; }
    [Parameter, EditorRequired] public string Mark { get; set; } = string.Empty;
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter, EditorRequired] public string Text { get; set; } = string.Empty;
}

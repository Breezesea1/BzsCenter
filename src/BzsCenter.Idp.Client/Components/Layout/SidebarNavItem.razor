@using Microsoft.AspNetCore.Components.Routing

@if (UseAnchor)
{
    <a class="@ClassName"
       href="@Href"
       title="@Label"
       aria-label="@Label"
       data-enhance-nav="@(DisableEnhancedNavigation ? "false" : null)"
       @onclick="OnClick">
        <span class="sidebar-nav-item__icon" aria-hidden="true">@Icon</span>
        <span class="sidebar-nav-item__label">@Label</span>
    </a>
}
else
{
    <NavLink class="@ClassName"
             href="@Href"
             Match="@Match"
             title="@Label"
             aria-label="@Label"
             data-enhance-nav="@(DisableEnhancedNavigation ? "false" : null)"
             @onclick="OnClick">
        <span class="sidebar-nav-item__icon" aria-hidden="true">@Icon</span>
        <span class="sidebar-nav-item__label">@Label</span>
    </NavLink>
}

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool DisableEnhancedNavigation { get; set; }
    [Parameter, EditorRequired] public string Href { get; set; } = string.Empty;
    [Parameter, EditorRequired] public RenderFragment Icon { get; set; } = default!;
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public bool UseAnchor { get; set; }

    private string ClassName => string.IsNullOrWhiteSpace(Class)
        ? "sidebar-nav-item sidebar-surface sidebar-surface--interactive"
        : $"sidebar-nav-item sidebar-surface sidebar-surface--interactive {Class}";
}

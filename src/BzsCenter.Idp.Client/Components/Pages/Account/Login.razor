@page "/login"
@layout EmptyLayout
@implements IAsyncDisposable
@using BzsCenter.Idp.Client.Infra.Blazor
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<Login> L
@inject IJSRuntime JS

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="login-page">
    <section class="login-hero" aria-hidden="true">
        <div class="login-brand">
            <div class="brand-icon">B</div>
            <span class="brand-name">BzsCenter</span>
        </div>

        <div class="hero-stage">
            <div class="hero-art" @ref="_heroArtRef">
                <div class="character purple">
                    <div class="eyes">
                        <span class="eye"><i class="pupil"></i></span>
                        <span class="eye"><i class="pupil"></i></span>
                    </div>
                </div>
                <div class="character charcoal">
                    <div class="eyes">
                        <span class="eye"><i class="pupil"></i></span>
                        <span class="eye"><i class="pupil"></i></span>
                    </div>
                </div>
                <div class="character orange">
                    <div class="eyes solid">
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                </div>
                <div class="character yellow">
                    <div class="eyes solid">
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                    <div class="mouth"></div>
                </div>
            </div>
        </div>

        <div class="hero-links">
            <a href="#">@L["PrivacyPolicy"]</a>
            <a href="#">@L["TermsOfService"]</a>
        </div>
    </section>

    <section class="login-panel">
        <div class="login-panel-top">
            <div class="mobile-brand">
                <div class="brand-icon">B</div>
                <span class="brand-name">BzsCenter</span>
            </div>
            <Preferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName"/>
        </div>
        <div class="login-card">

            <header class="login-header">
                <h1>@L["WelcomeBack"]</h1>
                <p>@L["EnterDetails"]</p>
            </header>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="login-error" role="alert">@ErrorMessage</div>
            }

            <form method="post" action="@BuildLoginAction()" class="login-form" autocomplete="off">
                <AntiforgeryToken />
                <div class="field">
                    <label for="username">@L["UserNameLabel"]</label>
                    <input id="username"
                           name="UserName"
                           type="text"
                           placeholder="@L["UserNamePlaceholder"]"
                           autocomplete="off"
                           autocapitalize="off"
                           autocorrect="off"
                           spellcheck="false"
                           required/>
                </div>

                <div class="field">
                    <label for="password">@L["PasswordLabel"]</label>
                    <div class="password-wrap">
                        <input
                             id="password"
                             name="Password"
                             type="@(_showPassword ? "text" : "password")"
                             placeholder="@L["PasswordPlaceholder"]"
                             autocomplete="new-password"
                             autocapitalize="off"
                             autocorrect="off"
                             spellcheck="false"
                             required/>
                        <button
                            class="password-toggle"
                            type="button"
                            @onclick="TogglePassword"
                            aria-label="@L["TogglePassword"]">
                            @if (_showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 3l18 18" fill="none" stroke="currentColor" stroke-width="2"
                                          stroke-linecap="round"/>
                                    <path d="M10.58 10.58a2 2 0 0 0 2.83 2.83" fill="none" stroke="currentColor"
                                          stroke-width="2" stroke-linecap="round"/>
                                    <path
                                        d="M9.88 5.09A10.94 10.94 0 0 1 12 4c5 0 9.27 3.11 11 8a11.85 11.85 0 0 1-4.29 5.54"
                                        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round"/>
                                    <path d="M6.61 6.61A11.84 11.84 0 0 0 1 12a11.82 11.82 0 0 0 6.17 6.61" fill="none"
                                          stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" fill="none"
                                          stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                    <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                <div class="meta-row">
                    <label class="remember">
                        <input type="checkbox" name="RememberMe" value="true"/>
                        <span>@L["Remember30Days"]</span>
                    </label>
                    <a href="#">@L["ForgotPassword"]</a>
                </div>

                <button type="submit" class="btn-primary btn-slide">
                    <span class="label-static">@L["LoginButton"]</span>
                    <span class="label-hover">
                        <span>@L["LoginButton"]</span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round"/>
                            <path d="m12 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </button>
            </form>

            <div class="social-login">
                <button type="button" class="btn-primary btn-slide btn-google">
                    <span class="label-static">
                        <svg class="google-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 488 512"
                             aria-hidden="true">
                            <path fill="currentColor"
                                  d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 126 23.4 172.9 61.9l-76.2 76.2C322.3 113.2 289.4 96 248 96c-88.8 0-160.1 71.9-160.1 160.1s71.3 160.1 160.1 160.1c98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 26.9 3.9 41.4z"/>
                        </svg>
                        @L["LoginWithGoogle"]
                    </span>
                    <span class="label-hover">
                        <svg class="google-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 488 512"
                             aria-hidden="true">
                            <path fill="currentColor"
                                  d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 126 23.4 172.9 61.9l-76.2 76.2C322.3 113.2 289.4 96 248 96c-88.8 0-160.1 71.9-160.1 160.1s71.3 160.1 160.1 160.1c98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 26.9 3.9 41.4z"/>
                        </svg>
                        <span>@L["LoginWithGoogle"]</span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round"/>
                            <path d="m12 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </button>
            </div>

            <p class="signup-tip">
                @L["NoAccount"]
                <a href="#">@L["SignUp"]</a>
            </p>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery] public string? Error { get; set; }

    private bool _showPassword;
    private ElementReference _heroArtRef;
    private IJSObjectReference? _loginModule;

    private string CurrentCultureName =>
        CultureInfo.CurrentUICulture.Name;

    private string CurrentThemeName =>
        "system";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _loginModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Account/Login.razor.js");
            await _loginModule.InvokeVoidAsync("initHeroTracking", _heroArtRef);
        }
    }

    public ValueTask DisposeAsync()
    {
        return BlazorUtils.DisposeJsModuleAsync(async () =>
        {
            if (_loginModule is null)
            {
                return;
            }

            await _loginModule.DisposeAsync();
            _loginModule = null;
        });
    }

    private string? ErrorMessage => Error switch
    {
        "invalid_credentials" => L["ErrorInvalidCredentials"].Value,
        "validation" => L["ErrorValidation"].Value,
        _ => null,
    };

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private string BuildLoginAction()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/account/login";
        }

        return QueryHelpers.AddQueryString("/account/login", new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }

}

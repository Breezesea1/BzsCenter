@using System.Security.Claims
@using ApexCharts
@using BzsCenter.Idp.Client.Services.Dashboard
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAdminDashboardClient DashboardClient
@inject IStringLocalizer<Dashboard> L
@inject NavigationManager NavigationManager

@if (_isLoading)
{
    <section class="dashboard-shell">
        <header class="dashboard-hero dashboard-skeleton-card">
            <div class="dashboard-skeleton-line wide"></div>
            <div class="dashboard-skeleton-line medium"></div>
        </header>

        <section class="dashboard-kpi-grid">
            @for (var index = 0; index < 4; index++)
            {
                <article class="dashboard-kpi-card dashboard-skeleton-card">
                    <div class="dashboard-skeleton-line short"></div>
                    <div class="dashboard-skeleton-line medium"></div>
                </article>
            }
        </section>
    </section>
}
else if (_summary is null)
{
    <section class="dashboard-shell">
        <header class="dashboard-hero">
            <div>
                <span class="dashboard-kicker">@L["Kicker"]</span>
                <h1>@L["AccessLimitedTitle"]</h1>
                <p>@L["AccessLimitedLead"]</p>
            </div>

            <div class="dashboard-hero-actions">
                <a class="dashboard-secondary-action" href="/login" data-enhance-nav="false">@L["GoToLogin"]</a>
            </div>
        </header>
    </section>
}
else
{
    <section class="dashboard-shell">
        <header class="dashboard-hero">
            <div>
                <span class="dashboard-kicker">@L["Kicker"]</span>
                <h1>@L["Title"]</h1>
                <p>@L["Lead"]</p>
            </div>

            <div class="dashboard-hero-actions">
                <a class="dashboard-secondary-action" href="/admin/users" data-enhance-nav="false">@L["ManageUsers"]</a>
                <a class="dashboard-primary-action" href="/admin/clients" data-enhance-nav="false">@L["ManageClients"]</a>
            </div>
        </header>

        <section class="dashboard-kpi-grid" aria-label="@L["Overview"]">
            <article class="dashboard-kpi-card dashboard-kpi-card-primary">
                <div class="dashboard-kpi-top">
                    <span class="dashboard-kpi-label">@L["TotalUsers"]</span>
                    <div class="dashboard-kpi-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                </div>
                <strong>@_summary.TotalUsers</strong>
                <div class="dashboard-kpi-trend dashboard-trend-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                    <span>+12%</span>
                    <span class="dashboard-kpi-trend-text">@(L["VsLastMonth"].ResourceNotFound ? "vs last month" : L["VsLastMonth"])</span>
                </div>
            </article>

            <article class="dashboard-kpi-card">
                <div class="dashboard-kpi-top">
                    <span class="dashboard-kpi-label">@L["AdminCoverage"]</span>
                    <div class="dashboard-kpi-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                </div>
                <strong>@AdminRatioDisplay</strong>
                <div class="dashboard-kpi-trend dashboard-trend-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                    <span>+4%</span>
                    <span class="dashboard-kpi-trend-text">@(L["VsLastMonth"].ResourceNotFound ? "vs last month" : L["VsLastMonth"])</span>
                </div>
            </article>

            <article class="dashboard-kpi-card">
                <div class="dashboard-kpi-top">
                    <span class="dashboard-kpi-label">@L["TotalClients"]</span>
                    <div class="dashboard-kpi-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                    </div>
                </div>
                <strong>@_summary.TotalClients</strong>
                <div class="dashboard-kpi-trend dashboard-trend-neutral">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    <span>0%</span>
                    <span class="dashboard-kpi-trend-text">@(L["VsLastMonth"].ResourceNotFound ? "vs last month" : L["VsLastMonth"])</span>
                </div>
            </article>

            <article class="dashboard-kpi-card dashboard-kpi-card-accent">
                <div class="dashboard-kpi-top">
                    <span class="dashboard-kpi-label">@L["ConfiguredScopes"]</span>
                    <div class="dashboard-kpi-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                </div>
                <strong>@_summary.TotalConfiguredScopes</strong>
                <div class="dashboard-kpi-trend dashboard-trend-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                    <span>+8%</span>
                    <span class="dashboard-kpi-trend-text">@(L["VsLastMonth"].ResourceNotFound ? "vs last month" : L["VsLastMonth"])</span>
                </div>
            </article>
        </section>

        <section class="dashboard-analytics-grid">
            <article class="dashboard-panel dashboard-panel-featured">
                <div class="dashboard-panel-header">
                    <div>
                        <span class="dashboard-panel-kicker">@L["ClientMix"]</span>
                        <h2>@L["ClientMixTitle"]</h2>
                    </div>
                    <p>@L["ClientMixLead"]</p>
                </div>

                <ApexChart TItem="DashboardChartPoint" Title="@L["ClientMixTitle"]" Options="_clientMixOptions">
                    <ApexPointSeries TItem="DashboardChartPoint"
                                     Items="_clientMixSeries"
                                     Name="@L["Clients"]"
                                     SeriesType="SeriesType.Bar"
                                     XValue="point => point.Label"
                                     YValue="point => point.Value" />
                </ApexChart>
            </article>

            <article class="dashboard-panel">
                <div class="dashboard-panel-header compact">
                    <div>
                        <span class="dashboard-panel-kicker">@L["RoleBalance"]</span>
                        <h2>@L["RoleBalanceTitle"]</h2>
                    </div>
                </div>

                <ApexChart TItem="DonutSlice" Options="_userRoleOptions">
                    <ApexPointSeries TItem="DonutSlice"
                                     Items="_userRoleSeries"
                                     Name="@L["Users"]"
                                     SeriesType="SeriesType.Donut"
                                     XValue="slice => slice.Label"
                                     YValue="slice => slice.Value" />
                </ApexChart>

                <div class="dashboard-goals-section">
                    <div class="dashboard-panel-header compact">
                        <div>
                            <span class="dashboard-panel-kicker">@(L["MonthlyGoals"].ResourceNotFound ? "Monthly Goals" : L["MonthlyGoals"])</span>
                            <h2>@(L["GoalsProgress"].ResourceNotFound ? "Progress" : L["GoalsProgress"])</h2>
                        </div>
                    </div>
                    <div class="dashboard-goal-list">
                        <div class="dashboard-goal-item">
                            <div class="dashboard-goal-label">
                                <span>@(L["UserGrowth"].ResourceNotFound ? "User Growth" : L["UserGrowth"])</span>
                                <span>72%</span>
                            </div>
                            <div class="dashboard-goal-bar">
                                <div class="dashboard-goal-fill" style="width: 72%; background: #2563eb;"></div>
                            </div>
                        </div>
                        <div class="dashboard-goal-item">
                            <div class="dashboard-goal-label">
                                <span>@(L["ClientOnboarding"].ResourceNotFound ? "Client Onboarding" : L["ClientOnboarding"])</span>
                                <span>45%</span>
                            </div>
                            <div class="dashboard-goal-bar">
                                <div class="dashboard-goal-fill" style="width: 45%; background: #0f766e;"></div>
                            </div>
                        </div>
                        <div class="dashboard-goal-item">
                            <div class="dashboard-goal-label">
                                <span>@(L["ScopeCoverage"].ResourceNotFound ? "Scope Coverage" : L["ScopeCoverage"])</span>
                                <span>88%</span>
                            </div>
                            <div class="dashboard-goal-bar">
                                <div class="dashboard-goal-fill" style="width: 88%; background: #ca8a04;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

            <article class="dashboard-panel dashboard-activity-panel">
                <div class="dashboard-panel-header compact">
                    <div>
                        <span class="dashboard-panel-kicker">@(L["Timeline"].ResourceNotFound ? "Timeline" : L["Timeline"])</span>
                        <h2>@(L["RecentActivity"].ResourceNotFound ? "Recent Activity" : L["RecentActivity"])</h2>
                    </div>
                </div>

                <div class="dashboard-activity-list">
                    <div class="dashboard-activity-item">
                        <div class="dashboard-activity-dot" style="background: #2563eb;"></div>
                        <div class="dashboard-activity-content">
                            <strong>@(L["ActivityUserAdded"].ResourceNotFound ? "New admin user registered" : L["ActivityUserAdded"])</strong>
                            <span>@(L["TimeJustNow"].ResourceNotFound ? "Just now" : L["TimeJustNow"])</span>
                        </div>
                    </div>
                    <div class="dashboard-activity-item">
                        <div class="dashboard-activity-dot" style="background: #0f766e;"></div>
                        <div class="dashboard-activity-content">
                            <strong>@(L["ActivityClientUpdated"].ResourceNotFound ? "Payment portal client updated" : L["ActivityClientUpdated"])</strong>
                            <span>@(L["TimeTwoHoursAgo"].ResourceNotFound ? "2 hours ago" : L["TimeTwoHoursAgo"])</span>
                        </div>
                    </div>
                    <div class="dashboard-activity-item">
                        <div class="dashboard-activity-dot" style="background: #ca8a04;"></div>
                        <div class="dashboard-activity-content">
                            <strong>@(L["ActivityScopeAdded"].ResourceNotFound ? "New billing scope created" : L["ActivityScopeAdded"])</strong>
                            <span>@(L["TimeYesterday"].ResourceNotFound ? "Yesterday" : L["TimeYesterday"])</span>
                        </div>
                    </div>
                    <div class="dashboard-activity-item">
                        <div class="dashboard-activity-dot" style="background: #64748b;"></div>
                        <div class="dashboard-activity-content">
                            <strong>@(L["ActivitySystemBackup"].ResourceNotFound ? "System configuration backup completed" : L["ActivitySystemBackup"])</strong>
                            <span>@(L["TimeTwoDaysAgo"].ResourceNotFound ? "2 days ago" : L["TimeTwoDaysAgo"])</span>
                        </div>
                    </div>
                </div>
            </article>
        </section>

        <section class="dashboard-detail-grid">
            <article class="dashboard-panel">
                <div class="dashboard-panel-header compact">
                    <div>
                        <span class="dashboard-panel-kicker">@L["QuickActions"]</span>
                        <h2>@L["QuickActionsTitle"]</h2>
                    </div>
                </div>

                <div class="dashboard-action-list">
                    <a class="dashboard-action-card" href="/admin/users" data-enhance-nav="false">
                        <strong>@L["ManageUsers"]</strong>
                        <span>@L["ManageUsersLead"]</span>
                    </a>
                    <a class="dashboard-action-card" href="/admin/clients" data-enhance-nav="false">
                        <strong>@L["ManageClients"]</strong>
                        <span>@L["ManageClientsLead"]</span>
                    </a>
                    <a class="dashboard-action-card" href="/admin/clients" data-enhance-nav="false">
                        <strong>@L["RegisterClient"]</strong>
                        <span>@L["RegisterClientLead"]</span>
                    </a>
                </div>
            </article>

            <article class="dashboard-panel dashboard-notes-panel">
                <div class="dashboard-panel-header compact">
                    <div>
                        <span class="dashboard-panel-kicker">@L["Guidance"]</span>
                        <h2>@L["GuidanceTitle"]</h2>
                    </div>
                </div>

                <ul class="dashboard-note-list">
                    <li>@L["GuidanceOne"]</li>
                    <li>@L["GuidanceTwo"]</li>
                    <li>@L["GuidanceThree"]</li>
                </ul>
            </article>
        </section>
    </section>
}

@code {
    private readonly List<DashboardChartPoint> _clientMixSeries = [];
    private readonly List<DonutSlice> _userRoleSeries = [];
    private const string AdminRoleName = "admin";
    private bool _isLoading = true;
    private AdminDashboardSummaryModel? _summary;
    private ApexChartOptions<DashboardChartPoint> _clientMixOptions = new();
    private ApexChartOptions<DonutSlice> _userRoleOptions = new();

    private string AdminRatioDisplay => _summary is null || _summary.TotalUsers == 0
        ? "0%"
        : $"{Math.Round((_summary.AdminUsers / (double)_summary.TotalUsers) * 100)}%";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString(
                "/login",
                new Dictionary<string, string?>
                {
                    ["returnUrl"] = "/",
                });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            _isLoading = false;
            return;
        }

        if (!authState.User.Claims.Any(claim =>
                string.Equals(claim.Type, ClaimTypes.Role, StringComparison.OrdinalIgnoreCase)
                && string.Equals(claim.Value, AdminRoleName, StringComparison.OrdinalIgnoreCase)))
        {
            _isLoading = false;
            return;
        }

        _summary = await DashboardClient.GetSummaryAsync();
        ConfigureCharts();
        _isLoading = false;
    }

    private void ConfigureCharts()
    {
        if (_summary is null)
        {
            return;
        }

        _clientMixSeries.Clear();
        _clientMixSeries.AddRange([
            new DashboardChartPoint(L["LoginApps"], _summary.InteractiveClients),
            new DashboardChartPoint(L["ServiceClients"], _summary.MachineClients),
            new DashboardChartPoint(L["ScopeMappings"], _summary.TotalPermissionMappings)
        ]);

        _clientMixOptions = new ApexChartOptions<DashboardChartPoint>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                Background = "transparent"
            },
            Colors = ["#0f766e", "#1d4ed8", "#ca8a04"],
            DataLabels = new DataLabels { Enabled = false },
            Grid = new Grid
            {
                BorderColor = "rgba(148, 163, 184, 0.16)"
            },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    BorderRadius = 10,
                    ColumnWidth = "52%"
                }
            }
        };

        _userRoleSeries.Clear();
        _userRoleSeries.AddRange([
            new DonutSlice(L["Admins"], _summary.AdminUsers),
            new DonutSlice(L["StandardUsers"], _summary.StandardUsers)
        ]);

        _userRoleOptions = new ApexChartOptions<DonutSlice>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                Background = "transparent"
            },
            Labels = [L["Admins"], L["StandardUsers"]],
            Colors = ["#2563eb", "#94a3b8"],
            Legend = new Legend
            {
                Position = LegendPosition.Bottom
            },
            DataLabels = new DataLabels { Enabled = false },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Labels = new DonutLabels
                        {
                            Show = true,
                            Total = new DonutLabelTotal
                            {
                                Show = true,
                                Label = L["Users"]
                            }
                        }
                    }
                }
            }
        };
    }

    private sealed record DashboardChartPoint(string Label, decimal Value);
    private sealed record DonutSlice(string Label, decimal Value);
}

@page "/Error"
@rendermode InteractiveWebAssembly
@layout MainLayout
@using System.Diagnostics
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Error> L

<PageTitle>@L["PageTitle"]</PageTitle>

<h1 class="text-danger">@L["Heading"]</h1>
<h2 class="text-danger">@L["Subheading"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@L["RequestIdLabel"]:</strong> <code>@RequestId</code>
    </p>
}

<h3>@L["DevelopmentModeHeading"]</h3>
<p>
    @DevelopmentModeIntroMarkup
</p>
<p>
    <strong>@L["DevelopmentModeWarning"]</strong>
    @DevelopmentModeDetailsMarkup
</p>

@code {
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    private MarkupString DevelopmentModeIntroMarkup =>
        new(string.Format(L["DevelopmentModeIntroHtml"].Value, BoldText(L["DevelopmentModeName"])));

    private MarkupString DevelopmentModeDetailsMarkup =>
        new(string.Format(
            L["DevelopmentModeDetailsHtml"].Value,
            BoldText("ASPNETCORE_ENVIRONMENT"),
            BoldText(L["DevelopmentModeName"])));

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id;

    private static string BoldText(string text) =>
        $"<strong>{text}</strong>";

}

@page "/admin/clients"
@rendermode InteractiveServer
@using BzsCenter.Idp.Services.Identity
@using BzsCenter.Idp.Services.Oidc
@using BzsCenter.Shared.Infrastructure.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using OpenIddict.Abstractions
@inject IHttpContextAccessor HttpContextAccessor
@inject IOidcClientService ClientService
@inject IStringLocalizer<ClientManagement> L
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@layout BzsCenter.Idp.Client.Components.Layout.MainLayout
@implements IAsyncDisposable

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <p class="admin-breadcrumb">@L["Overview"] &gt; @L["AppAccess"]</p>
                <h1>@L["PageTitle"]</h1>
                <p>@L["HeroLead"]</p>
            </div>

            <div class="admin-hero-actions">
                <button type="button" class="admin-primary-button" @onclick="BeginCreate" disabled="@_isBusy">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    @L["NewClient"]
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="admin-feedback @(_statusIsError ? "is-error" : "is-success")" role="status" aria-live="polite">
                @_statusMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_generatedClientSecret))
        {
            <div class="admin-secret-banner" role="alert">
                <div>
                    <strong>@L["ClientSecretGenerated"]</strong>
                    <p>@L["ClientSecretGeneratedLead"]</p>
                </div>
                <code>@_generatedClientSecret</code>
            </div>
        }

        <div class="admin-filter-tabs" role="group" aria-label='@L["FilterByProfile"]'>
            <button type="button" aria-pressed="@(_profileFilter == null)" class="admin-filter-tab @(_profileFilter == null ? "is-active" : "")" @onclick='() => SetProfileFilter(null)'>
                @L["All"] <span class="admin-tab-count">@_clients.Count</span>
            </button>
            <button type="button" aria-pressed="@(_profileFilter == OidcClientProfile.FirstPartyInteractive)" class="admin-filter-tab @(_profileFilter == OidcClientProfile.FirstPartyInteractive ? "is-active" : "")" @onclick='() => SetProfileFilter(OidcClientProfile.FirstPartyInteractive)'>
                @L["Interactive"] <span class="admin-tab-count">@InteractiveCount</span>
            </button>
            <button type="button" aria-pressed="@(_profileFilter == OidcClientProfile.FirstPartyMachine)" class="admin-filter-tab @(_profileFilter == OidcClientProfile.FirstPartyMachine ? "is-active" : "")" @onclick='() => SetProfileFilter(OidcClientProfile.FirstPartyMachine)'>
                @L["Machine"] <span class="admin-tab-count">@MachineCount</span>
            </button>
        </div>

        <div class="admin-grid-toolbar">
            <div class="admin-search-stack">
                <div class="admin-search-icon-field">
                    <svg class="admin-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                    <input id="client-search"
                            class="neo-input admin-search-input"
                            name="client-search"
                            type="search"
                            placeholder="@L["SearchPlaceholder"]"
                            value="@_searchTerm"
                            @oninput="HandleSearchInput"
                            autocomplete="off"
                            autocapitalize="off"
                            autocorrect="off"
                            spellcheck="false"
                            aria-label="@L["Search"]" />
                </div>
                <span class="admin-grid-summary">@FilteredSummary</span>
            </div>

            <div class="admin-grid-toolbar-actions">
                <button type="button" class="admin-ghost-button admin-toolbar-button" @onclick="LoadClientsAsync" disabled="@_isBusy">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <path d="M7 10l5 5 5-5" />
                        <path d="M12 15V3" />
                    </svg>
                    @L["Refresh"]
                </button>
            </div>
        </div>

        <div class="admin-table-shell" @ref="_tableShell">
            <table class="admin-table">
                <colgroup>
                    <col data-column-key="client" />
                    <col data-column-key="profile" />
                    <col data-column-key="grantTypes" />
                    <col data-column-key="scopes" />
                    <col data-column-key="redirectUris" />
                    <col data-column-key="actions" />
                </colgroup>
                <thead>
                    <tr>
                        <th data-column-key="client" data-min-width="236" aria-sort="@GetAriaSort(ClientSortField.Client)">
                            <div class="admin-column-head">
                                <button type="button" class="admin-sort-btn" @onclick='() => ToggleSort(ClientSortField.Client)'>@L["Client"] <span class="admin-sort-indicator" aria-hidden="true">@GetSortIndicator(ClientSortField.Client)</span></button>
                                <span class="admin-col-resizer" data-column-key="client" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Client"]]'></span>
                            </div>
                        </th>
                        <th data-column-key="profile" data-min-width="132" aria-sort="@GetAriaSort(ClientSortField.Profile)">
                            <div class="admin-column-head">
                                <button type="button" class="admin-sort-btn" @onclick='() => ToggleSort(ClientSortField.Profile)'>@L["Profile"] <span class="admin-sort-indicator" aria-hidden="true">@GetSortIndicator(ClientSortField.Profile)</span></button>
                                <span class="admin-col-resizer" data-column-key="profile" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Profile"]]'></span>
                            </div>
                        </th>
                        <th data-column-key="grantTypes" data-min-width="176">
                            <div class="admin-column-head">
                                <span class="admin-column-label">@L["GrantTypes"]</span>
                                <span class="admin-col-resizer" data-column-key="grantTypes" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["GrantTypes"]]'></span>
                            </div>
                        </th>
                        <th data-column-key="scopes" data-min-width="176">
                            <div class="admin-column-head">
                                <span class="admin-column-label">@L["Scopes"]</span>
                                <span class="admin-col-resizer" data-column-key="scopes" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Scopes"]]'></span>
                            </div>
                        </th>
                        <th data-column-key="redirectUris" data-min-width="188">
                            <div class="admin-column-head">
                                <span class="admin-column-label">@L["RedirectUris"]</span>
                                <span class="admin-col-resizer" data-column-key="redirectUris" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["RedirectUris"]]'></span>
                            </div>
                        </th>
                        <th data-column-key="actions" data-min-width="112" class="admin-actions-header">
                            <div class="admin-column-head admin-column-head-actions">
                                <span class="admin-column-label">@L["Actions"]</span>
                                <span class="admin-col-resizer" data-column-key="actions" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Actions"]]'></span>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (_filteredClients.Count == 0)
                    {
                        <tr class="admin-empty-row">
                            <td colspan="6">
                                <div class="admin-empty-state">
                                    <strong>@L["NoMatchingClients"]</strong>
                                    <p>@L["NoMatchingClientsLead"]</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var client in _visibleClients)
                        {
                            <tr class="admin-table-row" @key="client.ClientId">
                                <td class="admin-cell-primary">
                                    <div class="admin-client-row">
                                        <span class="admin-avatar" aria-hidden="true">@GetClientInitial(client)</span>
                                        <div class="admin-client-primary-cell">
                                            <strong>@(string.IsNullOrWhiteSpace(client.DisplayName) ? client.ClientId : client.DisplayName)</strong>
                                            <span class="admin-inline-code">@client.ClientId</span>
                                        </div>
                                    </div>
                                </td>
                                <td data-label='@L["Profile"].Value'>
                                    <span class="admin-badge @(client.Profile == OidcClientProfile.FirstPartyInteractive ? "is-admin" : "is-standard")">
                                        @FormatProfile(client.Profile)
                                    </span>
                                </td>
                                <td data-label='@L["GrantTypes"].Value'>
                                    <div class="admin-token-list">
                                        @foreach (var item in GetPreviewItems(client.GrantTypes))
                                        {
                                            <span class="admin-token">@item</span>
                                        }
                                        @if (GetOverflowCount(client.GrantTypes) > 0)
                                        {
                                            <span class="admin-token admin-token-overflow">+@GetOverflowCount(client.GrantTypes)</span>
                                        }
                                    </div>
                                </td>
                                <td data-label='@L["Scopes"].Value'>
                                    <div class="admin-token-list">
                                        @foreach (var item in GetPreviewItems(client.Scopes))
                                        {
                                            <span class="admin-token">@item</span>
                                        }
                                        @if (GetOverflowCount(client.Scopes) > 0)
                                        {
                                            <span class="admin-token admin-token-overflow">+@GetOverflowCount(client.Scopes)</span>
                                        }
                                    </div>
                                </td>
                                <td data-label='@L["RedirectUris"].Value'>
                                    <div class="admin-client-text-stack">
                                        @if (GetUriPreviewSource(client).Count == 0)
                                        {
                                            <span class="admin-user-meta">—</span>
                                        }
                                        else
                                        {
                                            @foreach (var uri in GetPreviewItems(GetUriPreviewSource(client)))
                                            {
                                                <span class="admin-user-meta admin-uri-preview">@uri</span>
                                            }
                                            @if (GetOverflowCount(GetUriPreviewSource(client)) > 0)
                                            {
                                                <span class="admin-user-meta">@L["MoreCount", GetOverflowCount(GetUriPreviewSource(client))]</span>
                                            }
                                        }
                                    </div>
                                </td>
                                <td data-label='@L["Actions"].Value'>
                                    <div class="admin-actions-column">
                                        <button type="button"
                                                class="admin-icon-button"
                                                title="@L["Edit"]"
                                                aria-label="@L["Edit"]"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => BeginEdit(client)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M12 20h9" />
                                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z" />
                                            </svg>
                                        </button>
                                        <button type="button"
                                                class="admin-icon-button danger"
                                                title="@L["Delete"]"
                                                aria-label="@L["Delete"]"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DeleteClientAsync(client.ClientId)"
                                                disabled="@_isBusy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M3 6h18" />
                                                <path d="M8 6V4h8v2" />
                                                <path d="M19 6l-1 14H6L5 6" />
                                                <path d="M10 11v6" />
                                                <path d="M14 11v6" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination-bar">
            <span class="admin-pagination-showing">@PageSummary</span>
            
            <div class="admin-pagination-controls">
                <label class="admin-page-size-field" for="client-page-size">
                    <span>@L["Rows"]</span>
                    <select id="client-page-size" class="neo-select admin-page-size-select" value="@_pageSize" @onchange="HandlePageSizeChange">
                        @foreach (var option in PageSizeOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                </label>

                <button type="button" class="admin-ghost-button admin-pagination-btn" @onclick="GoToPreviousPage" disabled="@(!CanGoToPreviousPage)">
                    @L["PreviousPage"]
                </button>
                @for (var p = Math.Max(1, _currentPage - 2); p <= Math.Min(TotalPages, _currentPage + 2); p++)
                {
                    var pageNum = p;
                    <button type="button" class="admin-pagination-page-btn @(pageNum == _currentPage ? "is-active" : "")" aria-current="@(pageNum == _currentPage ? "page" : null)" @onclick="() => GoToPage(pageNum)">
                        @pageNum
                    </button>
                }
                <button type="button" class="admin-ghost-button admin-pagination-btn" @onclick="GoToNextPage" disabled="@(!CanGoToNextPage)">
                    @L["NextPage"]
                </button>
            </div>
        </div>

        <ClientManagementDialog IsOpen="@_isEditorOpen"
                                IsEditing="@_isEditing"
                                IsBusy="@_isBusy"
                                ClientId="@_editor.ClientId"
                                ClientIdChanged="HandleClientIdChanged"
                                DisplayName="@_editor.DisplayName"
                                DisplayNameChanged="HandleDisplayNameChanged"
                                Profile="@_editor.Profile"
                                ProfileChanged="HandleProfileChanged"
                                ScopesText="@_editor.ScopesText"
                                ScopesTextChanged="HandleScopesTextChanged"
                                RedirectUrisText="@_editor.RedirectUrisText"
                                RedirectUrisTextChanged="HandleRedirectUrisTextChanged"
                                PostLogoutRedirectUrisText="@_editor.PostLogoutRedirectUrisText"
                                PostLogoutRedirectUrisTextChanged="HandlePostLogoutRedirectUrisTextChanged"
                                ClientSecret="@_editor.ClientSecret"
                                ClientSecretChanged="HandleClientSecretChanged"
                                FormErrors="@_formErrors"
                                OnClose="CloseEditor"
                                OnReset="ResetEditor"
                                OnSave="SaveAsync" />
    </section>
}

@code {
    private readonly List<OidcClientResponse> _clients = [];
    private readonly List<OidcClientResponse> _filteredClients = [];
    private readonly List<OidcClientResponse> _visibleClients = [];
    private readonly List<string> _formErrors = [];
    private static readonly int[] PageSizeOptions = [10, 20, 50];

    private ClientEditor _editor = CreateDefaultEditor();
    private ElementReference _tableShell;
    private bool _hasAccess;
    private bool _isBusy;
    private bool _isEditing;
    private bool _isEditorOpen;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private string _searchTerm = string.Empty;
    private OidcClientProfile? _profileFilter = null;
    private ClientSortField _sortField = ClientSortField.Client;
    private bool _sortDescending;
    private string? _generatedClientSecret;
    private string? _statusMessage;
    private bool _statusIsError;
    private IJSObjectReference? _tableModule;

    private int InteractiveCount => _clients.Count(static client => client.Profile == OidcClientProfile.FirstPartyInteractive);
    private int FilteredInteractiveCount => _filteredClients.Count(static client => client.Profile == OidcClientProfile.FirstPartyInteractive);
    private int FilteredMachineCount => _filteredClients.Count(static client => client.Profile == OidcClientProfile.FirstPartyMachine);
    private int MachineCount => _clients.Count(static client => client.Profile == OidcClientProfile.FirstPartyMachine);
    private bool CanGoToNextPage => _currentPage < TotalPages;
    private bool CanGoToPreviousPage => _currentPage > 1;
    private string FilteredSummary => _filteredClients.Count == 0
        ? L["SearchResultSummaryEmpty"].Value
        : L["SearchResultSummary", _filteredClients.Count].Value;
    private string PageSummary => _filteredClients.Count == 0
        ? L["PageSummaryEmpty"].Value
        : L["PageSummary", PageStartIndex, PageEndIndex, _filteredClients.Count].Value;
    private int PageEndIndex => Math.Min(_filteredClients.Count, ((_currentPage - 1) * _pageSize) + _visibleClients.Count);
    private int PageStartIndex => _filteredClients.Count == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filteredClients.Count / (double)_pageSize));
    private IQueryable<OidcClientResponse> VisibleClients => _visibleClients.AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        await LoadClientsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/admin-resizable-table.js");
        }

        if (_tableModule is not null && _filteredClients.Count > 0)
        {
            await _tableModule.InvokeVoidAsync("activate", _tableShell, "admin-clients-table");
        }
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/clients",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;
        return true;
    }

    private async Task LoadClientsAsync()
    {
        _isBusy = true;

        try
        {
            _clients.Clear();
            _clients.AddRange(await ClientService.GetAllAsync());
            ApplyFilter();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyFilter()
    {
        _filteredClients.Clear();

        IEnumerable<OidcClientResponse> query = _clients;
        
        if (_profileFilter.HasValue)
        {
            query = query.Where(c => c.Profile == _profileFilter.Value);
        }

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var searchTerm = _searchTerm.Trim();
            query = query
                .Select(client => new
                {
                    Client = client,
                    Score = AdminTableSearch.Score(
                        searchTerm,
                        client.ClientId,
                        client.DisplayName,
                        FormatProfile(client.Profile),
                        string.Join(' ', client.GrantTypes),
                        string.Join(' ', client.Scopes),
                        string.Join(' ', client.RedirectUris),
                        string.Join(' ', client.PostLogoutRedirectUris))
                })
                .Where(static result => result.Score.HasValue)
                .OrderBy(static result => result.Score)
                .Select(static result => result.Client);
        }

        query = ApplySort(query);

        _filteredClients.AddRange(query);
        UpdateVisibleClients(resetPage: true);
    }

    private void UpdateVisibleClients(bool resetPage = false)
    {
        if (resetPage)
        {
            _currentPage = 1;
        }

        _currentPage = Math.Clamp(_currentPage, 1, TotalPages);
        _visibleClients.Clear();
        _visibleClients.AddRange(_filteredClients
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize));
    }

    private void BeginCreate()
    {
        ResetEditorState();
        _isEditorOpen = true;
        ClearStatus();
    }

    private void BeginEdit(OidcClientResponse client)
    {
        _isEditing = true;
        _isEditorOpen = true;
        _editor = new ClientEditor
        {
            ClientId = client.ClientId,
            DisplayName = client.DisplayName ?? string.Empty,
            Profile = client.Profile,
            ScopesText = string.Join(Environment.NewLine, client.Scopes),
            RedirectUrisText = string.Join(Environment.NewLine, client.RedirectUris),
            PostLogoutRedirectUrisText = string.Join(Environment.NewLine, client.PostLogoutRedirectUris),
        };
        _generatedClientSecret = null;
        _formErrors.Clear();
        ClearStatus();
    }

    private void ResetEditor()
    {
        if (_isEditing)
        {
            var current = _clients.FirstOrDefault(client => string.Equals(client.ClientId, _editor.ClientId, StringComparison.Ordinal));
            if (current is not null)
            {
                BeginEdit(current);
                return;
            }
        }

        BeginCreate();
    }

    private void CloseEditor()
    {
        if (_isBusy)
        {
            return;
        }

        _isEditorOpen = false;
        ResetEditorState();
    }

    private async Task SaveAsync()
    {
        _formErrors.Clear();
        ClearStatus();
        _generatedClientSecret = null;

        ValidateEditor();
        if (_formErrors.Count > 0)
        {
            return;
        }

        _isBusy = true;

        try
        {
            var request = BuildRequest();

            if (_isEditing)
            {
                var result = await ClientService.UpdateAsync(_editor.ClientId, request);
                if (result.Status != OidcClientCommandStatus.Success)
                {
                    AddCommandErrors(result);
                    return;
                }

                _statusMessage = L["UpdatedStatus", _editor.ClientId].Value;
            }
            else
            {
                var result = await ClientService.RegisterAsync(request);
                if (result.Status != OidcClientCommandStatus.Success)
                {
                    AddCommandErrors(result);
                    return;
                }

                _statusMessage = L["RegisteredStatus", result.Value?.ClientId ?? _editor.DisplayName].Value;
                _generatedClientSecret = result.Value?.ClientSecret;
            }

            _statusIsError = false;
            await LoadClientsAsync();
            _isEditorOpen = false;
            _isEditing = false;
            _editor = CreateDefaultEditor();
            _formErrors.Clear();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteClientAsync(string clientId)
    {
        ClearStatus();
        _generatedClientSecret = null;
        _isBusy = true;

        try
        {
            var deleted = await ClientService.DeleteAsync(clientId);
            if (!deleted)
            {
                _statusMessage = L["ClientNoLongerExistsStatus", clientId].Value;
                _statusIsError = true;
                return;
            }

            await LoadClientsAsync();
            _statusMessage = L["DeletedStatus", clientId].Value;
            _statusIsError = false;

            if (string.Equals(_editor.ClientId, clientId, StringComparison.Ordinal))
            {
                _isEditorOpen = false;
                ResetEditorState();
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_editor.DisplayName))
        {
            _formErrors.Add(L["DisplayNameRequired"].Value);
        }

        var scopes = ParseLines(_editor.ScopesText);
        if (scopes.Length == 0)
        {
            _formErrors.Add(L["AtLeastOneScopeRequired"].Value);
        }

        if (_editor.Profile == OidcClientProfile.FirstPartyInteractive && ParseLines(_editor.RedirectUrisText).Length == 0)
        {
            _formErrors.Add(L["InteractiveClientRedirectRequired"].Value);
        }
    }

    private OidcClientUpsertRequest BuildRequest()
    {
        var scopes = ParseLines(_editor.ScopesText);

        if (_editor.Profile == OidcClientProfile.FirstPartyInteractive)
        {
            return new OidcClientUpsertRequest
            {
                ClientId = string.IsNullOrWhiteSpace(_editor.ClientId) ? null : _editor.ClientId.Trim(),
                DisplayName = _editor.DisplayName.Trim(),
                Profile = OidcClientProfile.FirstPartyInteractive,
                PublicClient = true,
                RequireProofKeyForCodeExchange = true,
                GrantTypes = [OpenIddictConstants.GrantTypes.AuthorizationCode, OpenIddictConstants.GrantTypes.RefreshToken],
                Scopes = scopes,
                RedirectUris = ParseLines(_editor.RedirectUrisText),
                PostLogoutRedirectUris = ParseLines(_editor.PostLogoutRedirectUrisText),
            };
        }

        return new OidcClientUpsertRequest
        {
            ClientId = string.IsNullOrWhiteSpace(_editor.ClientId) ? null : _editor.ClientId.Trim(),
            ClientSecret = string.IsNullOrWhiteSpace(_editor.ClientSecret) ? null : _editor.ClientSecret.Trim(),
            DisplayName = _editor.DisplayName.Trim(),
            Profile = OidcClientProfile.FirstPartyMachine,
            PublicClient = false,
            RequireProofKeyForCodeExchange = false,
            GrantTypes = [OpenIddictConstants.GrantTypes.ClientCredentials],
            Scopes = scopes,
        };
    }

    private void AddCommandErrors<T>(OidcClientCommandResult<T> result)
    {
        if (result.Errors.Length > 0)
        {
            _formErrors.AddRange(result.Errors.Select(LocalizeCommandError));
            return;
        }

        _formErrors.Add(result.Status switch
        {
            OidcClientCommandStatus.Conflict => L["ClientAlreadyExists"].Value,
            OidcClientCommandStatus.NotFound => L["ClientNotFound"].Value,
            _ => L["RequestFailedWithStatus", result.Status].Value,
        });
    }

    private string LocalizeCommandError(string error)
    {
        if (string.IsNullOrWhiteSpace(error))
        {
            return L["UnknownClientError"].Value;
        }

        if (error.StartsWith("Client '", StringComparison.Ordinal) && error.EndsWith("' already exists.", StringComparison.Ordinal))
        {
            var clientId = error[8..^17];
            return L["ClientAlreadyExistsForId", clientId].Value;
        }

        if (error.StartsWith("Invalid URI: '", StringComparison.Ordinal) && error.EndsWith("'.", StringComparison.Ordinal))
        {
            var uri = error[14..^2];
            return L["InvalidUri", uri].Value;
        }

        return error switch
        {
            "DisplayName is required." => L["DisplayNameRequired"].Value,
            "Public clients must not specify ClientSecret." => L["PublicClientsMustNotSpecifyClientSecret"].Value,
            "At least one grant type must be provided." => L["AtLeastOneGrantTypeRequired"].Value,
            "Authorization code clients must provide at least one redirect URI." => L["AuthorizationCodeRedirectRequired"].Value,
            "First-party interactive clients must be public clients." => L["InteractiveClientsMustBePublic"].Value,
            "First-party interactive clients only support authorization_code and refresh_token grants." => L["InteractiveClientsGrantTypesInvalid"].Value,
            "First-party interactive clients must require PKCE." => L["InteractiveClientsMustRequirePkce"].Value,
            "First-party machine clients must be confidential clients." => L["MachineClientsMustBeConfidential"].Value,
            "First-party machine clients only support the client_credentials grant." => L["MachineClientsGrantTypesInvalid"].Value,
            "First-party machine clients must not configure redirect URIs." => L["MachineClientsMustNotConfigureRedirectUris"].Value,
            "First-party machine clients must not configure post logout redirect URIs." => L["MachineClientsMustNotConfigurePostLogoutRedirectUris"].Value,
            "Current onboarding only supports first-party interactive (public + auth code/refresh token + PKCE) and first-party machine (confidential + client_credentials) clients." => L["UnsupportedOnboardingProfile"].Value,
            _ => L["UnknownClientError"].Value,
        };
    }

    private static string[] ParseLines(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return [];
        }

        return raw
            .Split([',', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private string FormatProfile(OidcClientProfile profile)
    {
        return profile switch
        {
            OidcClientProfile.FirstPartyInteractive => L["Interactive"].Value,
            OidcClientProfile.FirstPartyMachine => L["Machine"].Value,
            _ => profile.ToString(),
        };
    }

    private IReadOnlyList<string> GetUriPreviewSource(OidcClientResponse client)
    {
        if (client.RedirectUris.Length == 0 && client.PostLogoutRedirectUris.Length == 0)
        {
            return [];
        }

        return client.RedirectUris.Length > 0 ? client.RedirectUris : client.PostLogoutRedirectUris;
    }

    private static IReadOnlyList<string> GetPreviewItems(IReadOnlyList<string> values)
    {
        return values.Take(2).ToArray();
    }

    private static int GetOverflowCount(IReadOnlyList<string> values)
    {
        return Math.Max(0, values.Count - 2);
    }

    private static ClientEditor CreateDefaultEditor()
    {
        return new ClientEditor
        {
            Profile = OidcClientProfile.FirstPartyInteractive,
            ScopesText = PermissionConstants.ScopeApi,
        };
    }

    private void ResetEditorState()
    {
        _isEditing = false;
        _editor = CreateDefaultEditor();
        _formErrors.Clear();
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusIsError = false;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilter();
    }

    private void HandlePageSizeChange(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var pageSize) || pageSize <= 0)
        {
            return;
        }

        _pageSize = pageSize;
        UpdateVisibleClients(resetPage: true);
    }

    private void GoToNextPage()
    {
        if (!CanGoToNextPage)
        {
            return;
        }

        _currentPage++;
        UpdateVisibleClients();
    }

    private void GoToPreviousPage()
    {
        if (!CanGoToPreviousPage)
        {
            return;
        }

        _currentPage--;
        UpdateVisibleClients();
    }

    private Task HandleClientIdChanged(string value)
    {
        _editor.ClientId = value;
        return Task.CompletedTask;
    }

    private Task HandleClientSecretChanged(string value)
    {
        _editor.ClientSecret = value;
        return Task.CompletedTask;
    }

    private Task HandleDisplayNameChanged(string value)
    {
        _editor.DisplayName = value;
        return Task.CompletedTask;
    }

    private Task HandleProfileChanged(OidcClientProfile value)
    {
        _editor.Profile = value;
        return Task.CompletedTask;
    }

    private Task HandleScopesTextChanged(string value)
    {
        _editor.ScopesText = value;
        return Task.CompletedTask;
    }

    private Task HandleRedirectUrisTextChanged(string value)
    {
        _editor.RedirectUrisText = value;
        return Task.CompletedTask;
    }

    private Task HandlePostLogoutRedirectUrisTextChanged(string value)
    {
        _editor.PostLogoutRedirectUrisText = value;
        return Task.CompletedTask;
    }

    private void SetProfileFilter(OidcClientProfile? filter)
    {
        _profileFilter = filter;
        ApplyFilter();
    }

    private IEnumerable<OidcClientResponse> ApplySort(IEnumerable<OidcClientResponse> query)
    {
        return (_sortField, _sortDescending) switch
        {
            (ClientSortField.Client, false) => query.OrderBy(static client => client.ClientId, StringComparer.OrdinalIgnoreCase)
                .ThenBy(static client => client.DisplayName ?? client.ClientId, StringComparer.OrdinalIgnoreCase),
            (ClientSortField.Client, true) => query.OrderByDescending(static client => client.ClientId, StringComparer.OrdinalIgnoreCase)
                .ThenBy(static client => client.DisplayName ?? client.ClientId, StringComparer.OrdinalIgnoreCase),
            (ClientSortField.Profile, false) => query.OrderBy(static client => client.Profile).ThenBy(static client => client.DisplayName ?? client.ClientId, StringComparer.OrdinalIgnoreCase),
            (ClientSortField.Profile, true) => query.OrderByDescending(static client => client.Profile).ThenBy(static client => client.DisplayName ?? client.ClientId, StringComparer.OrdinalIgnoreCase),
            (_, true) => query.OrderByDescending(static client => client.ClientId, StringComparer.OrdinalIgnoreCase),
            _ => query.OrderBy(static client => client.ClientId, StringComparer.OrdinalIgnoreCase),
        };
    }

    private void ToggleSort(ClientSortField field)
    {
        if (_sortField == field)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortField = field;
            _sortDescending = false;
        }

        ApplyFilter();
    }

    private string GetAriaSort(ClientSortField field)
    {
        if (_sortField != field)
        {
            return "none";
        }

        return _sortDescending ? "descending" : "ascending";
    }

    private string GetSortIndicator(ClientSortField field)
    {
        if (_sortField != field)
        {
            return "↕";
        }

        return _sortDescending ? "↓" : "↑";
    }

    private static string GetClientInitial(OidcClientResponse client)
    {
        var name = string.IsNullOrWhiteSpace(client.DisplayName) ? client.ClientId : client.DisplayName;
        return string.IsNullOrWhiteSpace(name) ? "?" : name[0].ToString().ToUpperInvariant();
    }

    private static string GetClientAvatarColor(OidcClientResponse client)
    {
        var name = string.IsNullOrWhiteSpace(client.DisplayName) ? client.ClientId : client.DisplayName;
        if (string.IsNullOrWhiteSpace(name)) return "#64748b";
        string[] colors = ["#16a34a", "#2563eb", "#7c3aed", "#ea580c", "#0891b2", "#db2777"];
        return colors[Math.Abs(name[0]) % colors.Length];
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Clamp(page, 1, TotalPages);
        UpdateVisibleClients();
    }

    private sealed class ClientEditor
    {
        public string ClientId { get; set; } = string.Empty;
        public string ClientSecret { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public OidcClientProfile Profile { get; set; }
        public string ScopesText { get; set; } = string.Empty;
        public string RedirectUrisText { get; set; } = string.Empty;
        public string PostLogoutRedirectUrisText { get; set; } = string.Empty;
    }

    private enum ClientSortField
    {
        Client,
        Profile,
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableModule is null)
        {
            return;
        }

        try
        {
            await _tableModule.InvokeVoidAsync("dispose", _tableShell);
            await _tableModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }
}

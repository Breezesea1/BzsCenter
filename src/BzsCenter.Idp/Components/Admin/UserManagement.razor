@page "/admin/users"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using BzsCenter.Idp.Models
@using BzsCenter.Idp.Services.Identity
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.AspNetCore.Identity
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager
@inject IUserService UserService
@inject UserManager<BzsUser> UserManager
@inject IStringLocalizer<UserManagement> L
@inject IJSRuntime JS
@layout BzsCenter.Idp.Client.Components.Layout.MainLayout
@implements IAsyncDisposable

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <p class="admin-breadcrumb">@L["Overview"] &gt; @L["Identity"]</p>
                <h1>@L["PageTitle"]</h1>
                <p>@L["HeroLead"]</p>
            </div>

            <div class="admin-hero-actions">
                <button type="button" class="admin-primary-button" @onclick="BeginCreate" disabled="@_isBusy">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    @L["NewUser"]
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="admin-feedback @(_statusIsError ? "is-error" : "is-success")" role="status" aria-live="polite">@_statusMessage</div>
        }

        <div class="admin-filter-tabs" role="group" aria-label='@L["FilterByRole"]'>
            <button type="button" aria-pressed="@(_roleFilter == null)" class="admin-filter-tab @(_roleFilter == null ? "is-active" : "")" @onclick='() => SetRoleFilter(null)'>
                @L["All"] <span class="admin-tab-count">@_users.Count</span>
            </button>
            <button type="button" aria-pressed="@(_roleFilter == true)" class="admin-filter-tab @(_roleFilter == true ? "is-active" : "")" @onclick='() => SetRoleFilter(true)'>
                @L["Admin"] <span class="admin-tab-count">@AdminCount</span>
            </button>
            <button type="button" aria-pressed="@(_roleFilter == false)" class="admin-filter-tab @(_roleFilter == false ? "is-active" : "")" @onclick='() => SetRoleFilter(false)'>
                @L["Standard"] <span class="admin-tab-count">@(_users.Count - AdminCount)</span>
            </button>
        </div>

        <div class="admin-grid-toolbar">
            <div class="admin-search-stack">
                <div class="admin-search-icon-field">
                    <svg class="admin-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                    <input id="user-search"
                            name="user-search"
                            type="search"
                            placeholder="@L["SearchPlaceholder"]"
                            value="@_searchTerm"
                            @oninput="HandleSearchInput"
                            autocomplete="off"
                            autocapitalize="off"
                            autocorrect="off"
                            spellcheck="false"
                            aria-label="@L["Search"]" />
                </div>
                <span class="admin-grid-summary">@FilteredSummary</span>
            </div>

            <div class="admin-grid-toolbar-actions">
                <button type="button" class="admin-ghost-button admin-toolbar-button" @onclick="LoadUsersAsync" disabled="@_isBusy">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <path d="M7 10l5 5 5-5" />
                        <path d="M12 15V3" />
                    </svg>
                    @L["Refresh"]
                </button>
            </div>
        </div>

        <div class="admin-table-shell" @ref="_tableShell">
            @if (_filteredUsers.Count == 0)
            {
                <div class="admin-empty-state">
                    <strong>@L["NoMatchingUsers"]</strong>
                    <p>@L["NoMatchingUsersLead"]</p>
                </div>
            }
            else
            {
                <table class="admin-table">
                    <colgroup>
                        <col data-column-key="user" />
                        <col data-column-key="role" />
                        <col data-column-key="email" />
                        <col data-column-key="identifier" />
                        <col data-column-key="actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th data-column-key="user" data-min-width="208" aria-sort="@GetAriaSort(UserSortField.UserName)">
                                <div class="admin-column-head">
                                    <button type="button" class="admin-sort-btn" @onclick='() => ToggleSort(UserSortField.UserName)'>@L["User"] <span class="admin-sort-indicator" aria-hidden="true">@GetSortIndicator(UserSortField.UserName)</span></button>
                                    <span class="admin-col-resizer" data-column-key="user" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["User"]]'></span>
                                </div>
                            </th>
                            <th data-column-key="role" data-min-width="112" aria-sort="@GetAriaSort(UserSortField.Role)">
                                <div class="admin-column-head">
                                    <button type="button" class="admin-sort-btn" @onclick='() => ToggleSort(UserSortField.Role)'>@L["Role"] <span class="admin-sort-indicator" aria-hidden="true">@GetSortIndicator(UserSortField.Role)</span></button>
                                    <span class="admin-col-resizer" data-column-key="role" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Role"]]'></span>
                                </div>
                            </th>
                            <th data-column-key="email" data-min-width="188">
                                <div class="admin-column-head">
                                    <span class="admin-column-label">@L["Email"]</span>
                                    <span class="admin-col-resizer" data-column-key="email" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Email"]]'></span>
                                </div>
                            </th>
                            <th data-column-key="identifier" data-min-width="138" aria-sort="@GetAriaSort(UserSortField.Identifier)">
                                <div class="admin-column-head">
                                    <button type="button" class="admin-sort-btn" @onclick='() => ToggleSort(UserSortField.Identifier)'>@L["Identifier"] <span class="admin-sort-indicator" aria-hidden="true">@GetSortIndicator(UserSortField.Identifier)</span></button>
                                    <span class="admin-col-resizer" data-column-key="identifier" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Identifier"]]'></span>
                                </div>
                            </th>
                            <th data-column-key="actions" data-min-width="112" class="admin-actions-header">
                                <div class="admin-column-head admin-column-head-actions">
                                    <span class="admin-column-label">@L["Actions"]</span>
                                    <span class="admin-col-resizer" data-column-key="actions" role="separator" aria-orientation="vertical" tabindex="0" aria-label='@L["ResizeColumn", L["Actions"]]'></span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _visibleUsers)
                        {
                            <tr class="admin-table-row" @key="user.Id">
                                <td class="admin-cell-primary">
                                    <div class="admin-user-cell">
                                        <span class="admin-avatar" aria-hidden="true">@GetInitial(user.UserName)</span>
                                        <div class="admin-user-text">
                                            <strong>@user.UserName</strong>
                                            <span class="admin-user-meta">@(string.IsNullOrWhiteSpace(user.Email) ? L["ManagedAccount"] : user.Email)</span>
                                        </div>
                                    </div>
                                </td>
                                <td data-label='@L["Role"].Value'>
                                    <span class="admin-badge @(user.IsAdmin ? "is-admin" : "is-standard")">
                                        @(user.IsAdmin ? L["Admin"] : L["User"])
                                    </span>
                                </td>
                                <td data-label='@L["Email"].Value'>
                                    <span class="admin-user-meta">@(string.IsNullOrWhiteSpace(user.Email) ? "—" : user.Email)</span>
                                </td>
                                <td data-label='@L["Identifier"].Value'>
                                    <code class="admin-inline-code" title="@user.Id">@FormatShortIdentifier(user.Id)</code>
                                </td>
                                <td data-label='@L["Actions"].Value'>
                                    <div class="admin-actions-column">
                                        <button type="button"
                                                class="admin-icon-button"
                                                title="@L["Edit"]"
                                                aria-label="@L["Edit"]"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => BeginEdit(user)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M12 20h9" />
                                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z" />
                                            </svg>
                                        </button>
                                        <button type="button"
                                                class="admin-icon-button danger"
                                                title="@L["Delete"]"
                                                aria-label="@L["Delete"]"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DeleteUserAsync(user)"
                                                disabled="@(user.Id == _currentUserId || _isBusy)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M3 6h18" />
                                                <path d="M8 6V4h8v2" />
                                                <path d="M19 6l-1 14H6L5 6" />
                                                <path d="M10 11v6" />
                                                <path d="M14 11v6" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="admin-pagination-bar">
            <span class="admin-pagination-showing">@PageSummary</span>
            
            <div class="admin-pagination-controls">
                <label class="admin-page-size-field" for="user-page-size">
                    <span>@L["Rows"]</span>
                    <select id="user-page-size" value="@_pageSize" @onchange="HandlePageSizeChange">
                        @foreach (var option in PageSizeOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                </label>

                <button type="button" class="admin-ghost-button admin-pagination-btn" @onclick="GoToPreviousPage" disabled="@(!CanGoToPreviousPage)">
                    @L["PreviousPage"]
                </button>
                @for (var p = Math.Max(1, _currentPage - 2); p <= Math.Min(TotalPages, _currentPage + 2); p++)
                {
                    var pageNum = p;
                    <button type="button" class="admin-pagination-page-btn @(pageNum == _currentPage ? "is-active" : "")" aria-current="@(pageNum == _currentPage ? "page" : null)" @onclick="() => GoToPage(pageNum)">
                        @pageNum
                    </button>
                }
                <button type="button" class="admin-ghost-button admin-pagination-btn" @onclick="GoToNextPage" disabled="@(!CanGoToNextPage)">
                    @L["NextPage"]
                </button>
            </div>
        </div>

        <UserManagementDialog IsOpen="@_isEditorOpen"
                              IsEditing="@_isEditing"
                              IsBusy="@_isBusy"
                              UserName="@_editor.UserName"
                              UserNameChanged="HandleUserNameChanged"
                              Email="@_editor.Email"
                              EmailChanged="HandleEmailChanged"
                              Password="@_editor.Password"
                              PasswordChanged="HandlePasswordChanged"
                              IsAdmin="@_editor.IsAdmin"
                              IsAdminChanged="HandleIsAdminChanged"
                              FormErrors="@_formErrors"
                              OnClose="CloseEditor"
                              OnReset="ResetEditor"
                              OnSave="SaveAsync" />
    </section>
}

@code {
    private readonly List<UserRow> _users = [];
    private readonly List<UserRow> _filteredUsers = [];
    private readonly List<UserRow> _visibleUsers = [];
    private readonly List<string> _formErrors = [];
    private static readonly int[] PageSizeOptions = [10, 20, 50];

    private UserEditor _editor = new();
    private ElementReference _tableShell;
    private Guid _currentUserId;
    private bool _hasAccess;
    private bool _isBusy;
    private bool _isEditing;
    private bool _isEditorOpen;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private string _searchTerm = string.Empty;
    private bool? _roleFilter = null;
    private UserSortField _sortField = UserSortField.UserName;
    private bool _sortDescending;
    private string? _statusMessage;
    private bool _statusIsError;
    private IJSObjectReference? _tableModule;

    private int AdminCount => _users.Count(static user => user.IsAdmin);
    private int FilteredAdminCount => _filteredUsers.Count(static user => user.IsAdmin);
    private int FilteredStandardCount => _filteredUsers.Count - FilteredAdminCount;
    private bool CanGoToNextPage => _currentPage < TotalPages;
    private bool CanGoToPreviousPage => _currentPage > 1;
    private string FilteredSummary => _filteredUsers.Count == 0
        ? L["SearchResultSummaryEmpty"].Value
        : L["SearchResultSummary", _filteredUsers.Count].Value;
    private string PageSummary => _filteredUsers.Count == 0
        ? L["PageSummaryEmpty"].Value
        : L["PageSummary", PageStartIndex, PageEndIndex, _filteredUsers.Count].Value;
    private int PageEndIndex => Math.Min(_filteredUsers.Count, ((_currentPage - 1) * _pageSize) + _visibleUsers.Count);
    private int PageStartIndex => _filteredUsers.Count == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filteredUsers.Count / (double)_pageSize));
    private IQueryable<UserRow> VisibleUsers => _visibleUsers.AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        await LoadUsersAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tableModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/admin-resizable-table.js");
        }

        if (_tableModule is not null && _filteredUsers.Count > 0)
        {
            await _tableModule.InvokeVoidAsync("activate", _tableShell, "admin-users-table");
        }
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/users",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;

        if (Guid.TryParse(user.FindFirstValue(ClaimTypes.NameIdentifier), out var currentUserId))
        {
            _currentUserId = currentUserId;
        }

        return true;
    }

    private async Task LoadUsersAsync()
    {
        _isBusy = true;

        try
        {
            _users.Clear();

            var users = await UserService.GetAllAsync();
            foreach (var user in users)
            {
                _users.Add(new UserRow
                {
                    Id = user.Id,
                    UserName = user.UserName ?? string.Empty,
                    Email = user.Email,
                    IsAdmin = await UserManager.IsInRoleAsync(user, IdentitySeedConstants.AdminRoleName),
                });
            }

            ApplyFilter();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyFilter()
    {
        _filteredUsers.Clear();

        IEnumerable<UserRow> query = _users;

        if (_roleFilter.HasValue)
        {
            query = query.Where(u => u.IsAdmin == _roleFilter.Value);
        }

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var searchTerm = _searchTerm.Trim();
            query = query
                .Select(user => new
                {
                    User = user,
                    Score = AdminTableSearch.Score(
                        searchTerm,
                        user.UserName,
                        user.Email,
                        user.Id.ToString(),
                        user.IsAdmin ? L["RoleSearchAdmin"].Value : L["RoleSearchStandard"].Value)
                })
                .Where(static result => result.Score.HasValue)
                .OrderBy(static result => result.Score)
                .Select(static result => result.User);
        }

        query = ApplySort(query);

        _filteredUsers.AddRange(query);
        UpdateVisibleUsers(resetPage: true);
    }

    private void SetRoleFilter(bool? filter)
    {
        _roleFilter = filter;
        ApplyFilter();
    }

    private IEnumerable<UserRow> ApplySort(IEnumerable<UserRow> query)
    {
        return (_sortField, _sortDescending) switch
        {
            (UserSortField.Role, false) => query.OrderBy(static user => user.IsAdmin).ThenBy(static user => user.UserName, StringComparer.OrdinalIgnoreCase),
            (UserSortField.Role, true) => query.OrderByDescending(static user => user.IsAdmin).ThenBy(static user => user.UserName, StringComparer.OrdinalIgnoreCase),
            (UserSortField.Identifier, false) => query.OrderBy(static user => user.Id),
            (UserSortField.Identifier, true) => query.OrderByDescending(static user => user.Id),
            (_, true) => query.OrderByDescending(static user => user.UserName, StringComparer.OrdinalIgnoreCase),
            _ => query.OrderBy(static user => user.UserName, StringComparer.OrdinalIgnoreCase),
        };
    }

    private void ToggleSort(UserSortField field)
    {
        if (_sortField == field)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortField = field;
            _sortDescending = false;
        }

        ApplyFilter();
    }

    private string GetAriaSort(UserSortField field)
    {
        if (_sortField != field)
        {
            return "none";
        }

        return _sortDescending ? "descending" : "ascending";
    }

    private string GetSortIndicator(UserSortField field)
    {
        if (_sortField != field)
        {
            return "↕";
        }

        return _sortDescending ? "↓" : "↑";
    }

    private void UpdateVisibleUsers(bool resetPage = false)
    {
        if (resetPage)
        {
            _currentPage = 1;
        }

        _currentPage = Math.Clamp(_currentPage, 1, TotalPages);
        _visibleUsers.Clear();
        _visibleUsers.AddRange(_filteredUsers
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize));
    }

    private void BeginCreate()
    {
        ResetEditorState();
        _isEditorOpen = true;
        ClearStatus();
    }

    private void BeginEdit(UserRow user)
    {
        _isEditing = true;
        _isEditorOpen = true;
        _editor = new UserEditor
        {
            Id = user.Id,
            UserName = user.UserName,
            Email = user.Email,
            IsAdmin = user.IsAdmin,
        };
        _formErrors.Clear();
        ClearStatus();
    }

    private void ResetEditor()
    {
        if (_isEditing)
        {
            var current = _users.FirstOrDefault(user => user.Id == _editor.Id);
            if (current is not null)
            {
                BeginEdit(current);
                return;
            }
        }

        BeginCreate();
    }

    private void CloseEditor()
    {
        if (_isBusy)
        {
            return;
        }

        _isEditorOpen = false;
        ResetEditorState();
    }

    private async Task SaveAsync()
    {
        _formErrors.Clear();
        ClearStatus();

        ValidateEditor();
        if (_formErrors.Count > 0)
        {
            return;
        }

        _isBusy = true;

        try
        {
            IdentityResult result;

            if (_isEditing)
            {
                result = await UserService.UpdateAsync(_editor.Id, _editor.UserName.Trim(), NormalizeOptional(_editor.Email));
                CollectErrors(result);

                if (_formErrors.Count == 0 && !string.IsNullOrWhiteSpace(_editor.Password))
                {
                    var passwordResult = await UserService.EnsurePasswordAsync(_editor.Id, _editor.Password.Trim());
                    CollectErrors(passwordResult);
                }
            }
            else
            {
                result = await UserService.CreateAsync(
                    _editor.UserName.Trim(),
                    _editor.Password.Trim(),
                    NormalizeOptional(_editor.Email));
                CollectErrors(result);
            }

            if (_formErrors.Count > 0)
            {
                return;
            }

            var persistedUser = await UserService.GetByNameAsync(_editor.UserName.Trim());
            if (persistedUser is null)
            {
                _formErrors.Add(L["SavedUserCouldNotBeReloaded"].Value);
                return;
            }

            var roleResult = await SyncAdminRoleAsync(persistedUser, _editor.IsAdmin);
            CollectErrors(roleResult);
            if (_formErrors.Count > 0)
            {
                return;
            }

            await LoadUsersAsync();
            _statusMessage = _isEditing
                ? L["UpdatedUserStatus", _editor.UserName.Trim()].Value
                : L["CreatedUserStatus", _editor.UserName.Trim()].Value;
            _statusIsError = false;
            _isEditorOpen = false;
            _isEditing = false;
            _editor = new UserEditor();
            _formErrors.Clear();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteUserAsync(UserRow user)
    {
        ClearStatus();

        if (user.Id == _currentUserId)
        {
            _statusMessage = L["CannotDeleteCurrentSessionAccount"].Value;
            _statusIsError = true;
            return;
        }

        _isBusy = true;

        try
        {
            var result = await UserService.DeleteAsync(user.Id);
            if (!result.Succeeded)
            {
                _statusMessage = string.Join(" ", result.Errors.Select(LocalizeIdentityError));
                _statusIsError = true;
                return;
            }

            await LoadUsersAsync();
            _statusMessage = L["DeletedUserStatus", user.UserName].Value;
            _statusIsError = false;

            if (_editor.Id == user.Id)
            {
                _isEditorOpen = false;
                ResetEditorState();
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString().ToUpperInvariant();
    }

    private static string GetAvatarColor(string username)
    {
        if (string.IsNullOrWhiteSpace(username)) return "#64748b";
        string[] colors = ["#16a34a", "#2563eb", "#7c3aed", "#ea580c", "#0891b2", "#db2777"];
        return colors[Math.Abs(username[0]) % colors.Length];
    }

    private static string FormatShortIdentifier(Guid id)
    {
        return $"{id.ToString()[..8]}...";
    }

    private void ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_editor.UserName))
        {
            _formErrors.Add(L["UserNameRequired"].Value);
        }

        if (!_isEditing && string.IsNullOrWhiteSpace(_editor.Password))
        {
            _formErrors.Add(L["PasswordRequiredOnCreate"].Value);
        }

        if (!string.IsNullOrWhiteSpace(_editor.Email) &&
            !new EmailAddressAttribute().IsValid(_editor.Email))
        {
            _formErrors.Add(L["EmailMustBeValid"].Value);
        }
    }

    private async Task<IdentityResult> SyncAdminRoleAsync(BzsUser user, bool shouldBeAdmin)
    {
        var isAdmin = await UserManager.IsInRoleAsync(user, IdentitySeedConstants.AdminRoleName);
        if (shouldBeAdmin == isAdmin)
        {
            return IdentityResult.Success;
        }

        if (shouldBeAdmin)
        {
            return await UserManager.AddToRoleAsync(user, IdentitySeedConstants.AdminRoleName);
        }

        if (user.Id == _currentUserId)
        {
            return IdentityResult.Failed(new IdentityError
            {
                Code = "ProtectedUser",
                Description = L["CannotRemoveCurrentSessionAdminAccess"].Value,
            });
        }

        return await UserManager.RemoveFromRoleAsync(user, IdentitySeedConstants.AdminRoleName);
    }

    private void CollectErrors(IdentityResult result)
    {
        if (result.Succeeded)
        {
            return;
        }

        _formErrors.AddRange(result.Errors.Select(LocalizeIdentityError));
    }

    private string LocalizeIdentityError(IdentityError error)
    {
        return error.Code switch
        {
            "UserNotFound" => L["UserNotFound", ExtractQuotedValue(error.Description) ?? error.Description].Value,
            "ProtectedUser" => L["CannotRemoveCurrentSessionAdminAccess"].Value,
            nameof(IdentityErrorDescriber.DuplicateUserName) => L["DuplicateUserName", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.DuplicateEmail) => L["DuplicateEmail", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.InvalidUserName) => L["InvalidUserName", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.InvalidEmail) => L["InvalidEmail", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.PasswordTooShort) => L["PasswordTooShort"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresNonAlphanumeric) => L["PasswordRequiresNonAlphanumeric"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresDigit) => L["PasswordRequiresDigit"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresLower) => L["PasswordRequiresLower"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresUpper) => L["PasswordRequiresUpper"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresUniqueChars) => L["PasswordRequiresUniqueChars"].Value,
            _ => error.Description,
        };
    }

    private static string? ExtractQuotedValue(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var start = description.IndexOf('\'', StringComparison.Ordinal);
        if (start < 0)
        {
            return null;
        }

        var end = description.IndexOf('\'', start + 1);
        if (end <= start)
        {
            return null;
        }

        return description[(start + 1)..end];
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private void ResetEditorState()
    {
        _isEditing = false;
        _editor = new UserEditor();
        _formErrors.Clear();
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusIsError = false;
    }

    private sealed class UserEditor
    {
        public Guid Id { get; set; }
        public string UserName { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string Password { get; set; } = string.Empty;
        public bool IsAdmin { get; set; }
    }

    private sealed class UserRow
    {
        public Guid Id { get; init; }
        public string UserName { get; init; } = string.Empty;
        public string? Email { get; init; }
        public bool IsAdmin { get; init; }
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilter();
    }

    private void HandlePageSizeChange(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var pageSize) || pageSize <= 0)
        {
            return;
        }

        _pageSize = pageSize;
        UpdateVisibleUsers(resetPage: true);
    }

    private void GoToNextPage()
    {
        if (!CanGoToNextPage)
        {
            return;
        }

        _currentPage++;
        UpdateVisibleUsers();
    }

    private void GoToPreviousPage()
    {
        if (!CanGoToPreviousPage)
        {
            return;
        }

        _currentPage--;
        UpdateVisibleUsers();
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Clamp(page, 1, TotalPages);
        UpdateVisibleUsers();
    }

    private Task HandleUserNameChanged(string value)
    {
        _editor.UserName = value;
        return Task.CompletedTask;
    }

    private Task HandleEmailChanged(string? value)
    {
        _editor.Email = value;
        return Task.CompletedTask;
    }

    private Task HandlePasswordChanged(string value)
    {
        _editor.Password = value;
        return Task.CompletedTask;
    }

    private Task HandleIsAdminChanged(bool value)
    {
        _editor.IsAdmin = value;
        return Task.CompletedTask;
    }

    private enum UserSortField
    {
        UserName,
        Role,
        Identifier,
    }

    public async ValueTask DisposeAsync()
    {
        if (_tableModule is null)
        {
            return;
        }

        try
        {
            await _tableModule.InvokeVoidAsync("dispose", _tableShell);
            await _tableModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }
}

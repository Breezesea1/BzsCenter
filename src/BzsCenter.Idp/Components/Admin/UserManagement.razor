@page "/admin/users"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using BzsCenter.Idp.Models
@using BzsCenter.Idp.Services.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager
@inject IUserService UserService
@inject UserManager<BzsUser> UserManager
@inject IStringLocalizer<UserManagement> L
@layout BzsCenter.Idp.Client.Components.Layout.MainLayout

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <span class="admin-kicker">@L["Identity"]</span>
                <h1>@L["PageTitle"]</h1>
                <p>@L["HeroLead"]</p>
            </div>

            <div class="admin-hero-actions">
                <button type="button" class="admin-ghost-button" @onclick="LoadUsersAsync" disabled="@_isBusy">
                    @L["Refresh"]
                </button>
                <button type="button" class="admin-primary-button" @onclick="BeginCreate" disabled="@_isBusy">
                    @L["NewUser"]
                </button>
            </div>
        </header>

        <section class="admin-stats-grid" aria-label="@L["UserOverview"]">
            <article class="admin-stat-card">
                <span class="admin-stat-label">@L["TotalUsers"]</span>
                <strong>@_users.Count</strong>
                <p>@L["TotalUsersLead"]</p>
            </article>

            <article class="admin-stat-card">
                <span class="admin-stat-label">@L["Admins"]</span>
                <strong>@AdminCount</strong>
                <p>@L["AdminsLead"]</p>
            </article>

            <article class="admin-stat-card accent-card">
                <span class="admin-stat-label">@L["StandardUsers"]</span>
                <strong>@(_users.Count - AdminCount)</strong>
                <p>@L["StandardUsersLead"]</p>
            </article>
        </section>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="admin-feedback @(_statusIsError ? "is-error" : "is-success")" role="status">@_statusMessage</div>
        }

        <section class="admin-panel admin-list-panel">
            <div class="admin-panel-header">
                <div>
                    <h2>@L["Accounts"]</h2>
                    <p>@L["AccountsLead"]</p>
                </div>

                <label class="admin-search-field" for="user-search">
                    <span>@L["Search"]</span>
                    <input id="user-search"
                           type="search"
                           placeholder="@L["SearchPlaceholder"]"
                           value="@_searchTerm"
                           @oninput="HandleSearchInput" />
                </label>
            </div>

            <div class="admin-table-shell">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>@L["User"]</th>
                            <th>@L["Role"]</th>
                            <th>@L["Email"]</th>
                            <th>@L["Identifier"]</th>
                            <th class="admin-actions-column">@L["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_filteredUsers.Count == 0)
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="admin-empty-state">
                                        <strong>@L["NoMatchingUsers"]</strong>
                                        <p>@L["NoMatchingUsersLead"]</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in _filteredUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="admin-user-cell">
                                            <span class="admin-avatar" aria-hidden="true">@GetInitial(user.UserName)</span>
                                            <div>
                                                <strong>@user.UserName</strong>
                                                <span>@(user.Id == _currentUserId ? L["CurrentSession"] : L["ManagedAccount"])</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="admin-badge @(user.IsAdmin ? "is-admin" : "is-standard")">
                                            @(user.IsAdmin ? L["Admin"] : L["User"])
                                        </span>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                                    <td class="admin-mono">@user.Id</td>
                                    <td class="admin-actions-column">
                                        <button type="button" class="admin-row-button" @onclick="() => BeginEdit(user)">@L["Edit"]</button>
                                        <button type="button"
                                                class="admin-row-button danger"
                                                @onclick="() => DeleteUserAsync(user)"
                                                disabled="@(user.Id == _currentUserId || _isBusy)">
                                            @L["Delete"]
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <UserManagementDialog IsOpen="@_isEditorOpen"
                              IsEditing="@_isEditing"
                              IsBusy="@_isBusy"
                              UserName="@_editor.UserName"
                              UserNameChanged="HandleUserNameChanged"
                              Email="@_editor.Email"
                              EmailChanged="HandleEmailChanged"
                              Password="@_editor.Password"
                              PasswordChanged="HandlePasswordChanged"
                              IsAdmin="@_editor.IsAdmin"
                              IsAdminChanged="HandleIsAdminChanged"
                              FormErrors="@_formErrors"
                              OnClose="CloseEditor"
                              OnReset="ResetEditor"
                              OnSave="SaveAsync" />
    </section>
}

@code {
    private readonly List<UserRow> _users = [];
    private readonly List<UserRow> _filteredUsers = [];
    private readonly List<string> _formErrors = [];

    private UserEditor _editor = new();
    private Guid _currentUserId;
    private bool _hasAccess;
    private bool _isBusy;
    private bool _isEditing;
    private bool _isEditorOpen;
    private string _searchTerm = string.Empty;
    private string? _statusMessage;
    private bool _statusIsError;

    private int AdminCount => _users.Count(static user => user.IsAdmin);

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        await LoadUsersAsync();
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/users",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;

        if (Guid.TryParse(user.FindFirstValue(ClaimTypes.NameIdentifier), out var currentUserId))
        {
            _currentUserId = currentUserId;
        }

        return true;
    }

    private async Task LoadUsersAsync()
    {
        _isBusy = true;

        try
        {
            _users.Clear();

            var users = await UserService.GetAllAsync();
            foreach (var user in users)
            {
                _users.Add(new UserRow
                {
                    Id = user.Id,
                    UserName = user.UserName ?? string.Empty,
                    Email = user.Email,
                    IsAdmin = await UserManager.IsInRoleAsync(user, IdentitySeedConstants.AdminRoleName),
                });
            }

            ApplyFilter();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyFilter()
    {
        _filteredUsers.Clear();

        IEnumerable<UserRow> query = _users;
        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var searchTerm = _searchTerm.Trim();
            query = query.Where(user =>
                user.UserName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(user.Email) &&
                 user.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));
        }

        _filteredUsers.AddRange(query);
    }

    private void BeginCreate()
    {
        ResetEditorState();
        _isEditorOpen = true;
        ClearStatus();
    }

    private void BeginEdit(UserRow user)
    {
        _isEditing = true;
        _isEditorOpen = true;
        _editor = new UserEditor
        {
            Id = user.Id,
            UserName = user.UserName,
            Email = user.Email,
            IsAdmin = user.IsAdmin,
        };
        _formErrors.Clear();
        ClearStatus();
    }

    private void ResetEditor()
    {
        if (_isEditing)
        {
            var current = _users.FirstOrDefault(user => user.Id == _editor.Id);
            if (current is not null)
            {
                BeginEdit(current);
                return;
            }
        }

        BeginCreate();
    }

    private void CloseEditor()
    {
        if (_isBusy)
        {
            return;
        }

        _isEditorOpen = false;
        ResetEditorState();
    }

    private async Task SaveAsync()
    {
        _formErrors.Clear();
        ClearStatus();

        ValidateEditor();
        if (_formErrors.Count > 0)
        {
            return;
        }

        _isBusy = true;

        try
        {
            IdentityResult result;

            if (_isEditing)
            {
                result = await UserService.UpdateAsync(_editor.Id, _editor.UserName.Trim(), NormalizeOptional(_editor.Email));
                CollectErrors(result);

                if (_formErrors.Count == 0 && !string.IsNullOrWhiteSpace(_editor.Password))
                {
                    var passwordResult = await UserService.EnsurePasswordAsync(_editor.Id, _editor.Password.Trim());
                    CollectErrors(passwordResult);
                }
            }
            else
            {
                result = await UserService.CreateAsync(
                    _editor.UserName.Trim(),
                    _editor.Password.Trim(),
                    NormalizeOptional(_editor.Email));
                CollectErrors(result);
            }

            if (_formErrors.Count > 0)
            {
                return;
            }

            var persistedUser = await UserService.GetByNameAsync(_editor.UserName.Trim());
            if (persistedUser is null)
            {
                _formErrors.Add(L["SavedUserCouldNotBeReloaded"].Value);
                return;
            }

            var roleResult = await SyncAdminRoleAsync(persistedUser, _editor.IsAdmin);
            CollectErrors(roleResult);
            if (_formErrors.Count > 0)
            {
                return;
            }

            await LoadUsersAsync();
            _statusMessage = _isEditing
                ? L["UpdatedUserStatus", _editor.UserName.Trim()].Value
                : L["CreatedUserStatus", _editor.UserName.Trim()].Value;
            _statusIsError = false;
            _isEditorOpen = false;
            _isEditing = false;
            _editor = new UserEditor();
            _formErrors.Clear();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteUserAsync(UserRow user)
    {
        ClearStatus();

        if (user.Id == _currentUserId)
        {
            _statusMessage = L["CannotDeleteCurrentSessionAccount"].Value;
            _statusIsError = true;
            return;
        }

        _isBusy = true;

        try
        {
            var result = await UserService.DeleteAsync(user.Id);
            if (!result.Succeeded)
            {
                _statusMessage = string.Join(" ", result.Errors.Select(LocalizeIdentityError));
                _statusIsError = true;
                return;
            }

            await LoadUsersAsync();
            _statusMessage = L["DeletedUserStatus", user.UserName].Value;
            _statusIsError = false;

            if (_editor.Id == user.Id)
            {
                _isEditorOpen = false;
                ResetEditorState();
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[0].ToString().ToUpperInvariant();
    }

    private void ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_editor.UserName))
        {
            _formErrors.Add(L["UserNameRequired"].Value);
        }

        if (!_isEditing && string.IsNullOrWhiteSpace(_editor.Password))
        {
            _formErrors.Add(L["PasswordRequiredOnCreate"].Value);
        }

        if (!string.IsNullOrWhiteSpace(_editor.Email) &&
            !new EmailAddressAttribute().IsValid(_editor.Email))
        {
            _formErrors.Add(L["EmailMustBeValid"].Value);
        }
    }

    private async Task<IdentityResult> SyncAdminRoleAsync(BzsUser user, bool shouldBeAdmin)
    {
        var isAdmin = await UserManager.IsInRoleAsync(user, IdentitySeedConstants.AdminRoleName);
        if (shouldBeAdmin == isAdmin)
        {
            return IdentityResult.Success;
        }

        if (shouldBeAdmin)
        {
            return await UserManager.AddToRoleAsync(user, IdentitySeedConstants.AdminRoleName);
        }

        if (user.Id == _currentUserId)
        {
            return IdentityResult.Failed(new IdentityError
            {
                Code = "ProtectedUser",
                Description = L["CannotRemoveCurrentSessionAdminAccess"].Value,
            });
        }

        return await UserManager.RemoveFromRoleAsync(user, IdentitySeedConstants.AdminRoleName);
    }

    private void CollectErrors(IdentityResult result)
    {
        if (result.Succeeded)
        {
            return;
        }

        _formErrors.AddRange(result.Errors.Select(LocalizeIdentityError));
    }

    private string LocalizeIdentityError(IdentityError error)
    {
        return error.Code switch
        {
            "UserNotFound" => L["UserNotFound", ExtractQuotedValue(error.Description) ?? error.Description].Value,
            "ProtectedUser" => L["CannotRemoveCurrentSessionAdminAccess"].Value,
            nameof(IdentityErrorDescriber.DuplicateUserName) => L["DuplicateUserName", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.DuplicateEmail) => L["DuplicateEmail", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.InvalidUserName) => L["InvalidUserName", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.InvalidEmail) => L["InvalidEmail", ExtractQuotedValue(error.Description) ?? string.Empty].Value,
            nameof(IdentityErrorDescriber.PasswordTooShort) => L["PasswordTooShort"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresNonAlphanumeric) => L["PasswordRequiresNonAlphanumeric"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresDigit) => L["PasswordRequiresDigit"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresLower) => L["PasswordRequiresLower"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresUpper) => L["PasswordRequiresUpper"].Value,
            nameof(IdentityErrorDescriber.PasswordRequiresUniqueChars) => L["PasswordRequiresUniqueChars"].Value,
            _ => error.Description,
        };
    }

    private static string? ExtractQuotedValue(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var start = description.IndexOf('\'', StringComparison.Ordinal);
        if (start < 0)
        {
            return null;
        }

        var end = description.IndexOf('\'', start + 1);
        if (end <= start)
        {
            return null;
        }

        return description[(start + 1)..end];
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private void ResetEditorState()
    {
        _isEditing = false;
        _editor = new UserEditor();
        _formErrors.Clear();
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusIsError = false;
    }

    private sealed class UserEditor
    {
        public Guid Id { get; set; }
        public string UserName { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string Password { get; set; } = string.Empty;
        public bool IsAdmin { get; set; }
    }

    private sealed class UserRow
    {
        public Guid Id { get; init; }
        public string UserName { get; init; } = string.Empty;
        public string? Email { get; init; }
        public bool IsAdmin { get; init; }
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilter();
    }

    private Task HandleUserNameChanged(string value)
    {
        _editor.UserName = value;
        return Task.CompletedTask;
    }

    private Task HandleEmailChanged(string? value)
    {
        _editor.Email = value;
        return Task.CompletedTask;
    }

    private Task HandlePasswordChanged(string value)
    {
        _editor.Password = value;
        return Task.CompletedTask;
    }

    private Task HandleIsAdminChanged(bool value)
    {
        _editor.IsAdmin = value;
        return Task.CompletedTask;
    }
}

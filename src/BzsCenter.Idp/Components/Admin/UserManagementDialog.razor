@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagement> L

<AdminDialogShell IsOpen="@IsOpen"
                  IsBusy="@IsBusy"
                  Title="@DialogTitle"
                  Lead="@DialogLead"
                  CloseLabel="@L["Close"]"
                  InitialFocusSelector="@InitialFocusSelector"
                  OnClose="OnClose">
    <ChildContent>
        @if (FormErrors.Count > 0)
        {
            <div class="admin-feedback is-error">
                <strong>@L["CouldNotSaveUser"]</strong>
                <ul>
                    @foreach (var error in FormErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <div class="admin-form-grid">
            <label class="admin-field" for="editor-user-name">
                <span>@L["UserName"]</span>
                <input id="editor-user-name"
                       type="text"
                       value="@UserName"
                       @oninput="HandleUserNameInput"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false" />
            </label>

            <label class="admin-field" for="editor-email">
                <span>@L["Email"]</span>
                <input id="editor-email"
                       type="email"
                       value="@Email"
                       @oninput="HandleEmailInput"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false" />
            </label>

            <label class="admin-field" for="editor-password">
                <span>@(IsEditing ? L["NewPassword"] : L["Password"])</span>
                <input id="editor-password"
                       type="password"
                       value="@Password"
                       @oninput="HandlePasswordInput"
                       autocomplete="new-password"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false" />
                <small>@(IsEditing ? L["LeavePasswordBlankHelp"] : L["PasswordPolicyHelp"])</small>
            </label>

            <label class="admin-toggle-field" for="editor-admin-role">
                <input id="editor-admin-role" type="checkbox" checked="@IsAdmin" @onchange="HandleIsAdminInput" />
                <div>
                    <strong>@L["AdministratorAccess"]</strong>
                    <span>@L["AdministratorAccessLead"]</span>
                </div>
            </label>
        </div>
    </ChildContent>

    <Actions>
        <button type="button" class="admin-ghost-button" @onclick="OnReset" disabled="@IsBusy">
            @L["Reset"]
        </button>
        <button type="button" class="admin-primary-button" @onclick="OnSave" disabled="@IsBusy">
            @(IsBusy ? L["Saving"] : IsEditing ? L["SaveChanges"] : L["CreateUser"])
        </button>
    </Actions>
</AdminDialogShell>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> UserNameChanged { get; set; }
    [Parameter] public string? Email { get; set; }
    [Parameter] public EventCallback<string?> EmailChanged { get; set; }
    [Parameter] public string Password { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PasswordChanged { get; set; }
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public EventCallback<bool> IsAdminChanged { get; set; }
    [Parameter] public IReadOnlyList<string> FormErrors { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private string DialogLead => IsEditing ? L["EditUserLead"] : L["CreateUserLead"];
    private string InitialFocusSelector => "#editor-user-name";
    private string DialogTitle => IsEditing ? L["EditUser"] : L["CreateUser"];

    private Task HandleEmailInput(ChangeEventArgs args) => EmailChanged.InvokeAsync(args.Value?.ToString());

    private Task HandleIsAdminInput(ChangeEventArgs args)
    {
        if (args.Value is bool isChecked)
        {
            return IsAdminChanged.InvokeAsync(isChecked);
        }

        return Task.CompletedTask;
    }

    private Task HandlePasswordInput(ChangeEventArgs args) => PasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleUserNameInput(ChangeEventArgs args) => UserNameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}

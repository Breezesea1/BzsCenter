@using BzsCenter.Idp.Infra.Preferences
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en" data-theme="@ResolvedTheme">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["BzsCenter.Idp.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    @* Inline script: resolve "system" theme before first paint to prevent flash *@
    <script>
        (function () {
            var t = document.documentElement.getAttribute("data-theme");
            if (t === "system") {
                document.documentElement.setAttribute(
                    "data-theme",
                    window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
                );
            }
        })();
    </script>
    <HeadOutlet @rendermode="InteractiveServer"/>
</head>

<body>
<Routes @rendermode="InteractiveServer"/>
<ReconnectModal/>
<script src="@Assets["_framework/blazor.web.js"]"></script>
<script src="@Assets["lib/gsap/gsap.min.js"]"></script>
</body>

</html>

@code {
    private string ResolvedTheme
    {
        get
        {
            var cookie = HttpContextAccessor.HttpContext?.Request.Cookies[UiPreferences.ThemeCookieName];
            return UiPreferences.NormalizeTheme(cookie);
        }
    }
}

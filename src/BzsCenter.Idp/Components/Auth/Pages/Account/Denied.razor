@page "/account/denied"
@using BzsCenter.Idp.Components.Auth.Shared
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Denied> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="denied-page">
    <section class="denied-card">
        <div class="denied-top">
            <div class="denied-brand">
                <div class="brand-icon">B</div>
                <span class="brand-name">BzsCenter</span>
            </div>
            <AuthPreferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName"/>
        </div>

        <div class="denied-body">
            <div class="denied-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/>
                    <path d="M9.5 9.5 14.5 14.5M14.5 9.5 9.5 14.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>

            <h1>@L["Heading"]</h1>
            <p>@L["Lead"]</p>

            <div class="denied-actions">
                <a class="denied-primary" href="/" data-enhance-nav="false">@L["BackHome"]</a>
                <a class="denied-secondary" href="/login" data-enhance-nav="false">@L["SwitchAccount"]</a>
            </div>

            <p class="denied-help">@L["HelpText"]</p>
        </div>
    </section>
</div>

@code {
    private string CurrentCultureName => System.Globalization.CultureInfo.CurrentUICulture.Name;

    private string CurrentThemeName => "system";
}

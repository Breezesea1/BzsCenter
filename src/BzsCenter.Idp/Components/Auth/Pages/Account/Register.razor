@page "/register"
@rendermode InteractiveServer
@attribute [ExcludeFromInteractiveRouting]
@layout BzsCenter.Idp.Components.Auth.AuthLayout
@using System.Globalization
@using BzsCenter.Idp.Components.Auth.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Register> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_isRedirectingAuthenticatedUser)
{
    <div class="login-page">
        <LoginHero BrandName="OIDC"
                   BrandImageSrc="/oidc-brand.jpg"
                   PrivacyPolicyText='@L["PrivacyPolicy"]'
                   TermsOfServiceText='@L["TermsOfService"]'
                   UserNameInputId="register-username"
                   PasswordInputId="register-password" />

        <section class="login-panel">
            <div class="login-panel-top">
                <div class="mobile-brand">
                    <div class="brand-icon" aria-hidden="true">
                        <img src="/oidc-brand.jpg" alt="" width="32" height="32" />
                    </div>
                    <span class="brand-name">OIDC</span>
                </div>
                <AuthPreferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName" />
            </div>
            <div class="login-card">
                <header class="login-header">
                    <h1>@L["CreateAccount"]</h1>
                    <p>@L["RegisterLead"]</p>
                </header>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="login-error" role="alert">@ErrorMessage</div>
                }

                <form method="post" action="@BuildRegisterAction()" class="login-form register-form" autocomplete="off">
                    <AntiforgeryToken />

                    <NeoField Class="field" Label="@L["UserNameLabel"]" ForId="register-username">
                        <input id="register-username"
                               class="neo-input"
                               name="UserName"
                               type="text"
                               placeholder="@L["UserNamePlaceholder"]"
                               autocomplete="username"
                               autocapitalize="off"
                               autocorrect="off"
                               spellcheck="false"
                               required />
                    </NeoField>

                    <NeoField Class="field" Label="@L["EmailLabel"]" ForId="register-email">
                        <input id="register-email"
                               class="neo-input"
                               name="Email"
                               type="email"
                               placeholder="@L["EmailPlaceholder"]"
                               autocomplete="email"
                               autocapitalize="off"
                               autocorrect="off"
                               spellcheck="false"
                               required />
                    </NeoField>

                    <NeoField Class="field" Label="@L["PasswordLabel"]" ForId="register-password">
                        <div class="password-wrap">
                            <input id="register-password"
                                   class="neo-input"
                                   name="Password"
                                   type="@(_showPassword ? "text" : "password")"
                                   placeholder="@L["PasswordPlaceholder"]"
                                   autocomplete="new-password"
                                   autocapitalize="off"
                                   autocorrect="off"
                                   spellcheck="false"
                                   required />
                            <button class="password-toggle"
                                    type="button"
                                    @onclick="TogglePassword"
                                    aria-label="@L["TogglePassword"]">
                                @if (_showPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 3l18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                        <path d="M10.58 10.58a2 2 0 0 0 2.83 2.83" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                        <path d="M9.88 5.09A10.94 10.94 0 0 1 12 4c5 0 9.27 3.11 11 8a11.85 11.85 0 0 1-4.29 5.54" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M6.61 6.61A11.84 11.84 0 0 0 1 12a11.82 11.82 0 0 0 6.17 6.61" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </NeoField>

                    <NeoField Class="field" Label="@L["ConfirmPasswordLabel"]" ForId="register-confirm-password">
                        <div class="password-wrap">
                            <input id="register-confirm-password"
                                   class="neo-input"
                                   name="ConfirmPassword"
                                   type="@(_showConfirmPassword ? "text" : "password")"
                                   placeholder="@L["ConfirmPasswordPlaceholder"]"
                                   autocomplete="new-password"
                                   autocapitalize="off"
                                   autocorrect="off"
                                   spellcheck="false"
                                   required />
                            <button class="password-toggle"
                                    type="button"
                                    @onclick="ToggleConfirmPassword"
                                    aria-label="@L["TogglePassword"]">
                                @if (_showConfirmPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 3l18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                        <path d="M10.58 10.58a2 2 0 0 0 2.83 2.83" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                        <path d="M9.88 5.09A10.94 10.94 0 0 1 12 4c5 0 9.27 3.11 11 8a11.85 11.85 0 0 1-4.29 5.54" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M6.61 6.61A11.84 11.84 0 0 0 1 12a11.82 11.82 0 0 0 6.17 6.61" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </NeoField>

                    <button type="submit" class="btn-primary btn-slide">
                        <span class="label-static">@L["RegisterButton"]</span>
                        <span class="label-hover">
                            <span>@L["RegisterButton"]</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                <path d="m12 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                </form>

                <p class="signup-tip">
                    @L["AlreadyHaveAccount"]
                    <a href="@BuildLoginHref()">@L["LoginLink"]</a>
                </p>
            </div>
        </section>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery] public string? Error { get; set; }

    private bool _isRedirectingAuthenticatedUser;
    private bool _showPassword;
    private bool _showConfirmPassword;

    private string CurrentCultureName => CultureInfo.CurrentUICulture.Name;
    private string CurrentThemeName => "system";

    private string? ErrorMessage => Error switch
    {
        "validation" => L["ErrorValidation"].Value,
        "password_mismatch" => L["ErrorPasswordMismatch"].Value,
        "registration_failed" => L["ErrorRegistrationFailed"].Value,
        _ => null,
    };

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authenticationState.User.Identity?.IsAuthenticated == true)
        {
            _isRedirectingAuthenticatedUser = true;
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPassword()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private string BuildRegisterAction()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/account/register";
        }

        return QueryHelpers.AddQueryString("/account/register", new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }

    private string BuildLoginHref()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/login";
        }

        return QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }
}

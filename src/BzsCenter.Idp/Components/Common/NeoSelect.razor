@typeparam TValue where TValue : notnull
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="neo-select-shell @Class" @ref="_rootRef">
    <button id="@Id"
            type="button"
            class="neo-select-trigger @GetTriggerStateClass()"
            aria-label="@AriaLabel"
            aria-expanded="@_isOpen.ToString().ToLowerInvariant()"
            aria-controls="@ListboxId"
            aria-haspopup="listbox"
            disabled="@Disabled"
            @onclick="ToggleOpenAsync"
            @onkeydown="HandleKeyDownAsync">
        <span class="neo-select-trigger__copy">
            <span class="neo-select-trigger__label">@CurrentOption?.Label</span>

            @if (!string.IsNullOrWhiteSpace(CurrentOption?.Description))
            {
                <span class="neo-select-trigger__description">@CurrentOption.Description</span>
            }
        </span>

        <span class="neo-select-trigger__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none">
                <path d="m5 7.5 5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </button>

    @if (_isOpen)
    {
        <div id="@ListboxId"
             class="neo-select-panel"
             role="listbox"
             aria-label="@AriaLabel"
             @onclick:stopPropagation="true">
            @for (var index = 0; index < Options.Count; index++)
            {
                var option = Options[index];
                var isSelected = EqualityComparer<TValue>.Default.Equals(option.Value, Value);
                var isActive = index == _activeIndex;

                <div id="@GetOptionId(index)"
                     class="neo-select-option @GetOptionStateClass(isSelected, isActive)"
                     role="option"
                     aria-selected="@isSelected.ToString().ToLowerInvariant()"
                     tabindex="-1"
                     data-neo-select-index="@index"
                     @onclick="() => SelectOptionAsync(option.Value)">
                    <span class="neo-select-option__label">@option.Label</span>

                    @if (!string.IsNullOrWhiteSpace(option.Description))
                    {
                        <span class="neo-select-option__description">@option.Description</span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private readonly string _listboxId = $"neo-select-listbox-{Guid.NewGuid():N}";
    private ElementReference _rootRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<NeoSelect<TValue>>? _dotNetRef;
    private bool _isOpen;
    private int _activeIndex;

    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Id { get; set; } = $"neo-select-{Guid.NewGuid():N}";
    [Parameter, EditorRequired] public IReadOnlyList<NeoSelectOption<TValue>> Options { get; set; } = [];
    [Parameter, EditorRequired] public TValue Value { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<TValue> ValueChanged { get; set; }

    private string ListboxId => _listboxId;

    private NeoSelectOption<TValue>? CurrentOption =>
        Options.FirstOrDefault(option => EqualityComparer<TValue>.Default.Equals(option.Value, Value))
        ?? Options.FirstOrDefault();

    protected override void OnParametersSet()
    {
        if (Options.Count == 0)
        {
            _activeIndex = 0;
            return;
        }

        var selectedIndex = Options
            .Select((option, index) => new { option, index })
            .FirstOrDefault(item => EqualityComparer<TValue>.Default.Equals(item.option.Value, Value))?.index;

        _activeIndex = Math.Clamp(selectedIndex ?? 0, 0, Options.Count - 1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/neo-select.js");
            await _module.InvokeVoidAsync("init", _rootRef, Id, _dotNetRef);
        }

        if (_module is not null && _isOpen)
        {
            await _module.InvokeVoidAsync("syncActiveOption", _rootRef, GetActiveDescendantId());
        }
    }

    [JSInvokable]
    public void ClosePanel()
    {
        if (_isOpen)
        {
            _isOpen = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (Disabled || Options.Count == 0)
        {
            return;
        }

        switch (args.Key)
        {
            case "ArrowDown":
                if (!_isOpen)
                {
                    OpenPanel();
                    return;
                }

                MoveActiveIndex(1);
                return;
            case "ArrowUp":
                if (!_isOpen)
                {
                    OpenPanel();
                    return;
                }

                MoveActiveIndex(-1);
                return;
            case "Home":
                OpenPanel();
                _activeIndex = 0;
                return;
            case "End":
                OpenPanel();
                _activeIndex = Options.Count - 1;
                return;
            case " ":
            case "Enter":
                if (!_isOpen)
                {
                    OpenPanel();
                    return;
                }

                await SelectOptionAsync(Options[_activeIndex].Value);
                return;
            case "Escape":
                _isOpen = false;
                return;
            case "Tab":
                _isOpen = false;
                return;
            default:
                return;
        }
    }

    private Task ToggleOpenAsync()
    {
        if (Disabled || Options.Count == 0)
        {
            return Task.CompletedTask;
        }

        if (_isOpen)
        {
            _isOpen = false;
            return Task.CompletedTask;
        }

        OpenPanel();
        return Task.CompletedTask;
    }

    private async Task SelectOptionAsync(TValue value)
    {
        _isOpen = false;
        await ValueChanged.InvokeAsync(value);
    }

    private void OpenPanel()
    {
        if (Options.Count == 0)
        {
            return;
        }

        _isOpen = true;
        var selectedIndex = Options
            .Select((option, index) => new { option, index })
            .FirstOrDefault(item => EqualityComparer<TValue>.Default.Equals(item.option.Value, Value))?.index;
        _activeIndex = Math.Clamp(selectedIndex ?? 0, 0, Options.Count - 1);
    }

    private void MoveActiveIndex(int step)
    {
        if (Options.Count == 0)
        {
            return;
        }

        _activeIndex = (_activeIndex + step + Options.Count) % Options.Count;
    }

    private string? GetActiveDescendantId()
    {
        return _isOpen && Options.Count > 0
            ? GetOptionId(_activeIndex)
            : null;
    }

    private string GetOptionId(int index) => $"{Id}-option-{index}";

    private string? GetOptionStateClass(bool isSelected, bool isActive)
    {
        if (isSelected && isActive)
        {
            return "is-selected is-active";
        }

        if (isSelected)
        {
            return "is-selected";
        }

        if (isActive)
        {
            return "is-active";
        }

        return null;
    }

    private string? GetTriggerStateClass()
    {
        return _isOpen ? "is-open" : null;
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();

        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("dispose", _rootRef);
            await _module.DisposeAsync();
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }
}

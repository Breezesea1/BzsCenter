@using BzsCenter.Idp.Infra.Preferences
@using System.Globalization
@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-links">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
            <Preferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName"/>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string CurrentCultureName =>
        CultureInfo.CurrentUICulture.Name;

    private string CurrentThemeName =>
        HttpContextAccessor.HttpContext?.Request.Cookies[UiPreferences.ThemeCookieName]
        ?? UiPreferences.DefaultTheme;
}

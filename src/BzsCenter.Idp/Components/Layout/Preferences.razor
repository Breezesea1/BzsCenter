@implements IAsyncDisposable
@using BzsCenter.Idp.Infra.Blazor
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Preferences> L
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="pref-widget" @ref="_widgetRef">
    <button class="pref-trigger"
            type="button"
            @onclick="ToggleOpen"
            aria-label="@L["Preferences"]"
            aria-expanded="@_open.ToString().ToLowerInvariant()">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </button>

    @if (_open)
    {
        <div class="pref-panel" role="menu" aria-label="@L["Preferences"]">
            <div class="pref-section">
                <span class="pref-label">@L["Theme"]</span>
                <div class="pref-options" role="group" aria-label="@L["Theme"]">
                    <button type="button"
                            class="pref-opt @(_currentTheme == "light" ? "active" : "")"
                            role="menuitemradio"
                            aria-checked="@(_currentTheme == "light" ? "true" : "false")"
                            @onclick='() => SetTheme("light")'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
                                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        @L["Light"]
                    </button>
                    <button type="button"
                            class="pref-opt @(_currentTheme == "dark" ? "active" : "")"
                            role="menuitemradio"
                            aria-checked="@(_currentTheme == "dark" ? "true" : "false")"
                            @onclick='() => SetTheme("dark")'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        @L["Dark"]
                    </button>
                    <button type="button"
                            class="pref-opt @(_currentTheme == "system" ? "active" : "")"
                            role="menuitemradio"
                            aria-checked="@(_currentTheme == "system" ? "true" : "false")"
                            @onclick='() => SetTheme("system")'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="2" y="3" width="20" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M8 21h8M12 17v4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        @L["System"]
                    </button>
                </div>
            </div>

            <div class="pref-divider"></div>

            <div class="pref-section">
                <span class="pref-label">@L["Language"]</span>
                <div class="pref-options" role="group" aria-label="@L["Language"]">
                    <button type="button"
                            class="pref-opt @(_currentCulture == "zh-CN" ? "active" : "")"
                            role="menuitemradio"
                            aria-checked="@(_currentCulture == "zh-CN" ? "true" : "false")"
                            @onclick='() => SetCulture("zh-CN")'>
                        中文
                    </button>
                    <button type="button"
                            class="pref-opt @(_currentCulture == "en-US" ? "active" : "")"
                            role="menuitemradio"
                            aria-checked="@(_currentCulture == "en-US" ? "true" : "false")"
                            @onclick='() => SetCulture("en-US")'>
                        EN
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? CurrentCulture { get; set; }
    [Parameter] public string? CurrentTheme { get; set; }

    private bool _open;
    private string _currentTheme = "system";
    private string _currentCulture = "zh-CN";
    private ElementReference _widgetRef;
    private IJSObjectReference? _prefModule;
    private DotNetObjectReference<Preferences>? _dotNetRef;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(CurrentTheme))
        {
            _currentTheme = CurrentTheme;
        }

        if (!string.IsNullOrWhiteSpace(CurrentCulture))
        {
            _currentCulture = CurrentCulture;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _prefModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Layout/Preferences.razor.js");
            await _prefModule.InvokeVoidAsync("init", _widgetRef, _dotNetRef);

            var cookieTheme = await _prefModule.InvokeAsync<string?>("getThemeCookie");
            if (!string.IsNullOrWhiteSpace(cookieTheme) && cookieTheme != _currentTheme)
            {
                _currentTheme = cookieTheme;
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public void ClosePanel()
    {
        if (_open)
        {
            _open = false;
            StateHasChanged();
        }
    }

    private void ToggleOpen()
    {
        _open = !_open;
    }

    private async Task SetTheme(string theme)
    {
        _currentTheme = theme;
        _open = false;

        if (_prefModule is not null)
        {
            await _prefModule.InvokeVoidAsync("applyTheme", theme);
        }

        var returnUrl = BuildLocalReturnUrl();
        var url = $"/preferences/set-theme?theme={Uri.EscapeDataString(theme)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private void SetCulture(string culture)
    {
        _currentCulture = culture;
        _open = false;

        var returnUrl = BuildLocalReturnUrl();
        var url = $"/preferences/set-culture?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private string BuildLocalReturnUrl()
    {
        var current = new Uri(Nav.Uri, UriKind.Absolute);
        var returnUrl = $"{current.PathAndQuery}{current.Fragment}";
        return string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl;
    }

    public ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        return BlazorUtils.DisposeJsModuleAsync(async () =>
        {
            if (_prefModule is null)
            {
                return;
            }

            await _prefModule.DisposeAsync();
            _prefModule = null;
        });
    }
}

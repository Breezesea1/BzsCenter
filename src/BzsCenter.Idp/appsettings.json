{
  "IdpIssuer": "https://idp.example.com",
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownIpNetworks": []
  },
  "DataProtection": {
    "ApplicationName": "BzsCenter.Idp",
    "StorageDirectory": "/var/lib/bzscenter/idp-dpkeys",
    "KeyLifetimeDays": 90
  },
  "Oidc": {
    "SigninCertificatePath": [],
    "SigninCertificatePassword": [],
    "EncryptionCertificatePath": [],
    "EncryptionCertificatePassword": [],
    "AccessTokenLifetimeMinutes": 45,
    "RefreshTokenLifetimeDays": 7,
    "DisableAccessTokenEncryption": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

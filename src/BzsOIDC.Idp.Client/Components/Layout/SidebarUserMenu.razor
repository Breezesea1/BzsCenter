<div class="sidebar-user-menu__trigger sidebar-surface" title="@Name">
    @if (OnAvatarClick.HasDelegate)
    {
        <SidebarAvatar Value="@Avatar"
                       AriaLabel="@AvatarButtonAriaLabel"
                       ControlsId="@AvatarControlsId"
                       IsExpanded="@AvatarExpanded"
                       OnClick="@OnAvatarClick" />
    }
    else
    {
        <SidebarAvatar Value="@Avatar" />
    }

    <div class="sidebar-user-menu__body">
        <span class="sidebar-user-menu__name">@Name</span>
        <span class="sidebar-user-menu__secondary">@SecondaryText</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Avatar { get; set; } = string.Empty;
    [Parameter] public string AvatarButtonAriaLabel { get; set; } = "Open user menu";
    [Parameter] public string? AvatarControlsId { get; set; }
    [Parameter] public bool AvatarExpanded { get; set; }
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter] public EventCallback OnAvatarClick { get; set; }
    [Parameter, EditorRequired] public string SecondaryText { get; set; } = string.Empty;
}

@page "/admin/oidc/topology"
@rendermode InteractiveServer
@using BzsOIDC.Idp.Services.Identity
@using BzsOIDC.Idp.Services.Oidc
@using BzsOIDC.Shared.Infrastructure.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject IOidcClientService ClientService
@inject IOidcScopeService ScopeService
@inject IPermissionCatalogService PermissionCatalogService
@inject IStringLocalizer<ScopeManagement> L
@inject NavigationManager NavigationManager
@layout BzsOIDC.Idp.Client.Components.Layout.MainLayout

<PageTitle>@L["TopologyPageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <p class="admin-breadcrumb">@L["Overview"] &gt; @L["TopologyBreadcrumb"]</p>
                <h1>@L["TopologyPageTitle"]</h1>
                <p>@L["TopologyPageLead"]</p>
            </div>
        </header>

        <div class="admin-overview-grid">
            <section class="admin-overview-card">
                <header class="admin-overview-card-header">
                    <div>
                        <h2>@L["Clients"]</h2>
                        <p>@L["TopologyClientsLead"]</p>
                    </div>
                </header>
                <div class="admin-topology-list">
                    @foreach (var client in _clients)
                    {
                        <div class="admin-topology-row">
                            <strong>@(string.IsNullOrWhiteSpace(client.DisplayName) ? client.ClientId : client.DisplayName)</strong>
                            <span class="admin-user-meta">@client.AuthFlow</span>
                            <div class="admin-token-list">
                                @foreach (var scope in client.Scopes)
                                {
                                    <span class="admin-token">@scope</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="admin-overview-card">
                <header class="admin-overview-card-header">
                    <div>
                        <h2>@L["Scopes"]</h2>
                        <p>@L["TopologyScopesLead"]</p>
                    </div>
                </header>
                <div class="admin-topology-list">
                    @foreach (var scope in _scopes)
                    {
                        <div class="admin-topology-row">
                            <strong>@scope.Name</strong>
                            <div class="admin-token-list">
                                @foreach (var permission in GetScopePermissions(scope.Name))
                                {
                                    <span class="admin-token">@permission</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>
    </section>
}

@code {
    private readonly List<OidcClientResponse> _clients = [];
    private readonly List<OidcScopeResponse> _scopes = [];
    private readonly List<PermissionDefinitionResponse> _permissionDefinitions = [];
    private bool _hasAccess;

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        _clients.AddRange(await ClientService.GetAllAsync());
        _scopes.AddRange(await ScopeService.GetAllAsync());
        _permissionDefinitions.AddRange((await PermissionCatalogService.GetResourcesAsync()).SelectMany(static resource => resource.Permissions));
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/oidc/topology",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;
        return true;
    }

    private IReadOnlyList<string> GetScopePermissions(string scopeName)
    {
        return _permissionDefinitions
            .Where(mapping => mapping.ReleaseScopes.Contains(scopeName, StringComparer.OrdinalIgnoreCase))
            .Select(static mapping => mapping.Name)
            .OrderBy(static permission => permission, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }
}


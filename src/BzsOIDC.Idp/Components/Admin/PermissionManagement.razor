@page "/admin/permissions"
@rendermode InteractiveServer
@using BzsOIDC.Idp.Services.Identity
@using BzsOIDC.Shared.Infrastructure.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject IPermissionCatalogService PermissionCatalogService
@inject IStringLocalizer<PermissionManagement> L
@inject NavigationManager NavigationManager
@layout BzsOIDC.Idp.Client.Components.Layout.MainLayout

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <p class="admin-breadcrumb">@L["Overview"] &gt; @L["PermissionCenter"]</p>
                <h1>@L["PageTitle"]</h1>
                <p>@L["HeroLead"]</p>
            </div>
            <div class="admin-hero-actions">
                <button type="button" class="admin-primary-button" @onclick="CreateDefaultResourceAsync" disabled="@_isBusy">
                    @L["NewResource"]
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="admin-feedback @(_statusIsError ? "is-error" : "is-success")" role="status" aria-live="polite">
                @_statusMessage
            </div>
        }

        <div class="admin-overview-grid">
            <section class="admin-overview-card">
                <header class="admin-overview-card-header">
                    <div>
                        <h2>@L["CatalogOverview"]</h2>
                        <p>@L["CatalogOverviewLead"]</p>
                    </div>
                </header>
                <div class="admin-overview-stats">
                    <span class="admin-user-meta">@L["ResourceCount", _resources.Count]</span>
                    <span class="admin-user-meta">@L["PermissionCount", Permissions.Count]</span>
                    <span class="admin-user-meta">@L["ReleaseScopeCount", Permissions.Sum(static permission => permission.ReleaseScopes.Length)]</span>
                    <span class="admin-user-meta">@L["RoleAssignmentCount", Permissions.Sum(static permission => permission.AssignedRoles.Length)]</span>
                </div>
            </section>
        </div>

        <div class="admin-grid-toolbar">
            <div class="admin-search-stack">
                <div class="admin-search-icon-field">
                    <input id="permission-search"
                           class="neo-input admin-search-input"
                           type="search"
                           placeholder="@L["SearchPlaceholder"]"
                           value="@_searchTerm"
                           @oninput="HandleSearchInput"
                           autocomplete="off"
                           aria-label="@L["Search"]" />
                </div>
                <span class="admin-grid-summary">@L["SearchResultSummary", FilteredResources.Count]</span>
            </div>
            <div class="admin-grid-toolbar-actions">
                <button type="button" class="admin-ghost-button admin-toolbar-button" @onclick="LoadAsync" disabled="@_isBusy">
                    @L["Refresh"]
                </button>
            </div>
        </div>

        @if (_resources.Count == 0)
        {
            <div class="admin-empty-state">
                <strong>@L["EmptyTitle"]</strong>
                <p>@L["EmptyLead"]</p>
            </div>
        }
        else
        {
            <div class="admin-permission-center">
                <div class="admin-permission-column admin-permission-column-primary">
                    <section class="admin-overview-card admin-permission-panel">
                        <header class="admin-overview-card-header">
                            <div>
                                <h2>@L["Resources"]</h2>
                            </div>
                        </header>
                        <div class="admin-topology-list">
                            @foreach (var resource in FilteredResources)
                            {
                                <button type="button"
                                        class="admin-topology-row admin-topology-button @(IsSelectedResource(resource) ? "is-active" : string.Empty)"
                                        @onclick="() => SelectResource(resource.Key)">
                                    <strong>@resource.DisplayName</strong>
                                    <span class="admin-user-meta">@resource.Key · @L["PermissionCount", resource.Permissions.Length]</span>
                                </button>
                            }
                        </div>
                    </section>

                    <section class="admin-overview-card admin-permission-panel admin-permission-panel-fill">
                        <header class="admin-overview-card-header">
                            <div>
                                <h2>@L["BusinessPermissions"]</h2>
                            </div>
                            @if (SelectedResource is not null)
                            {
                                <button type="button" class="admin-secondary-button" @onclick="CreateDefaultPermissionAsync" disabled="@_isBusy">
                                    @L["NewPermission"]
                                </button>
                            }
                        </header>
                        @if (SelectedResource is null)
                        {
                            <p class="admin-user-meta">@L["SelectResourcePrompt"]</p>
                        }
                        else
                        {
                            <div class="admin-topology-list">
                                @foreach (var permission in SelectedResource.Permissions.OrderBy(static permission => permission.Name, StringComparer.OrdinalIgnoreCase))
                                {
                                    <button type="button"
                                            class="admin-topology-row admin-topology-button admin-permission-row @(IsSelectedPermission(permission) ? "is-active" : string.Empty)"
                                            @onclick="() => SelectPermission(permission.Name)">
                                        <div class="admin-permission-row-main">
                                            <strong>@permission.Name</strong>
                                            <span class="admin-user-meta">@permission.DisplayName · @(permission.IsActive ? L["Active"] : L["Inactive"])</span>
                                        </div>
                                        <div class="admin-token-list admin-permission-row-scopes">
                                            @foreach (var scope in permission.ReleaseScopes.Take(2))
                                            {
                                                <span class="admin-token">@scope</span>
                                            }
                                            @if (permission.ReleaseScopes.Length > 2)
                                            {
                                                <span class="admin-token admin-token-overflow">+@(permission.ReleaseScopes.Length - 2)</span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                    </section>
                </div>

                <div class="admin-permission-column admin-permission-column-secondary">
                    <section class="admin-overview-card admin-permission-panel">
                        <header class="admin-overview-card-header">
                            <div>
                                <h2>@L["ReleaseScopes"]</h2>
                            </div>
                        </header>
                        @if (SelectedPermission is null)
                        {
                            <p class="admin-user-meta">@L["SelectPermissionPrompt"]</p>
                        }
                        else
                        {
                            <NeoField Label="@L["ReleaseScopes"]" ForId="release-scopes-editor" Hint="@L["ReleaseScopesEditorHelp"]">
                                <textarea id="release-scopes-editor"
                                          class="neo-textarea admin-release-scope-editor"
                                          rows="2"
                                          value="@_releaseScopesText"
                                          @oninput="args => _releaseScopesText = args.Value?.ToString() ?? string.Empty"></textarea>
                            </NeoField>
                            <button type="button" class="admin-secondary-button" @onclick="SaveReleaseScopesAsync" disabled="@_isBusy">
                                @L["SaveReleaseScopes"]
                            </button>
                        }
                    </section>

                    <section class="admin-overview-card admin-permission-panel">
                        <header class="admin-overview-card-header">
                            <div>
                                <h2>@L["RoleAssignments"]</h2>
                            </div>
                        </header>
                        @if (SelectedPermission is null)
                        {
                            <p class="admin-user-meta">@L["SelectPermissionPrompt"]</p>
                        }
                        else
                        {
                            <p class="admin-user-meta">@L["RoleAssignmentsReadOnlyLead"]</p>
                            <div class="admin-token-list">
                                @foreach (var role in SelectedPermission.AssignedRoles)
                                {
                                    <span class="admin-token">@role.RoleName</span>
                                }
                                @if (SelectedPermission.AssignedRoles.Length == 0)
                                {
                                    <span class="admin-user-meta">@L["NoAssignedRoles"]</span>
                                }
                            </div>
                        }
                    </section>

                    <section class="admin-overview-card admin-permission-panel admin-permission-topology-card">
                        <header class="admin-overview-card-header">
                            <div>
                                <h2>@L["Topology"]</h2>
                            </div>
                        </header>
                        @if (SelectedPermission is null)
                        {
                            <p class="admin-user-meta">@L["SelectPermissionPrompt"]</p>
                        }
                        else
                        {
                            <div class="admin-scope-relation-preview">
                                <article class="admin-scope-relation-card">
                                    <div class="admin-scope-relation-node">
                                        <span>@L["ResourceApi"]</span>
                                        <strong>@SelectedPermission.ResourceKey</strong>
                                    </div>
                                    <div class="admin-scope-relation-branches">
                                        <div>
                                            <span>@L["BusinessPermission"]</span>
                                            <div class="admin-token-list"><span class="admin-token">@SelectedPermission.Name</span></div>
                                        </div>
                                        <div>
                                            <span>@L["ReleaseScopes"]</span>
                                            <div class="admin-token-list">
                                                @foreach (var scope in SelectedPermission.ReleaseScopes)
                                                {
                                                    <span class="admin-token">@scope</span>
                                                }
                                            </div>
                                        </div>
                                        <div>
                                            <span>@L["RoleAssignments"]</span>
                                            <div class="admin-token-list">
                                                @foreach (var role in SelectedPermission.AssignedRoles)
                                                {
                                                    <span class="admin-token">@role.RoleName</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </div>
                        }
                    </section>
                </div>
            </div>
        }
    </section>
}

@code {
    private readonly List<ProtectedResourceResponse> _resources = [];
    private string? _selectedResourceKey;
    private string? _selectedPermissionName;
    private string _searchTerm = string.Empty;
    private string _releaseScopesText = string.Empty;
    private string? _statusMessage;
    private bool _hasAccess;
    private bool _isBusy;
    private bool _statusIsError;

    private IReadOnlyList<ProtectedResourceResponse> FilteredResources => string.IsNullOrWhiteSpace(_searchTerm)
        ? _resources
        : _resources
            .Where(resource =>
                resource.Key.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                resource.DisplayName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                resource.Permissions.Any(permission => permission.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)))
            .ToArray();

    private IReadOnlyList<PermissionDefinitionResponse> Permissions => _resources.SelectMany(static resource => resource.Permissions).ToArray();
    private ProtectedResourceResponse? SelectedResource => _resources.FirstOrDefault(resource => string.Equals(resource.Key, _selectedResourceKey, StringComparison.OrdinalIgnoreCase));
    private PermissionDefinitionResponse? SelectedPermission => Permissions.FirstOrDefault(permission => string.Equals(permission.Name, _selectedPermissionName, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        await LoadAsync();
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/permissions",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;
        return true;
    }

    private async Task LoadAsync()
    {
        _isBusy = true;
        try
        {
            _resources.Clear();
            _resources.AddRange(await PermissionCatalogService.GetResourcesAsync());
            _selectedResourceKey ??= _resources.FirstOrDefault()?.Key;
            _selectedPermissionName ??= SelectedResource?.Permissions.FirstOrDefault()?.Name;
            SyncReleaseScopeEditor();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CreateDefaultResourceAsync()
    {
        var key = $"resource-{_resources.Count + 1}";
        await PermissionCatalogService.UpsertResourceAsync(key, new ProtectedResourceUpsertRequest
        {
            DisplayName = key,
        });
        _selectedResourceKey = key;
        _selectedPermissionName = null;
        _statusMessage = L["ResourceCreated", key].Value;
        _statusIsError = false;
        await LoadAsync();
    }

    private async Task CreateDefaultPermissionAsync()
    {
        if (SelectedResource is null)
        {
            return;
        }

        var permissionName = $"{SelectedResource.Key}.read";
        await PermissionCatalogService.UpsertPermissionAsync(SelectedResource.Key, permissionName, new PermissionDefinitionUpsertRequest
        {
            DisplayName = permissionName,
        });
        await PermissionCatalogService.SyncReleaseScopesAsync(permissionName, [SelectedResource.Key]);
        _selectedPermissionName = permissionName;
        _statusMessage = L["PermissionCreated", permissionName].Value;
        _statusIsError = false;
        await LoadAsync();
    }

    private async Task SaveReleaseScopesAsync()
    {
        if (SelectedPermission is null)
        {
            return;
        }

        var result = await PermissionCatalogService.SyncReleaseScopesAsync(SelectedPermission.Name, ParseLines(_releaseScopesText));
        _statusIsError = result.Status != PermissionCatalogCommandStatus.Success;
        _statusMessage = result.Status == PermissionCatalogCommandStatus.Success
            ? L["ReleaseScopesSaved", SelectedPermission.Name].Value
            : string.Join(Environment.NewLine, result.Errors);
        await LoadAsync();
    }

    private void SelectResource(string resourceKey)
    {
        _selectedResourceKey = resourceKey;
        _selectedPermissionName = SelectedResource?.Permissions.FirstOrDefault()?.Name;
        SyncReleaseScopeEditor();
    }

    private void SelectPermission(string permissionName)
    {
        _selectedPermissionName = permissionName;
        SyncReleaseScopeEditor();
    }

    private void SyncReleaseScopeEditor()
    {
        _releaseScopesText = SelectedPermission is null
            ? string.Empty
            : string.Join(Environment.NewLine, SelectedPermission.ReleaseScopes);
    }

    private bool IsSelectedResource(ProtectedResourceResponse resource)
    {
        return string.Equals(resource.Key, _selectedResourceKey, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsSelectedPermission(PermissionDefinitionResponse permission)
    {
        return string.Equals(permission.Name, _selectedPermissionName, StringComparison.OrdinalIgnoreCase);
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
    }

    private static string[] ParseLines(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return [];
        }

        return raw
            .Split([',', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }
}


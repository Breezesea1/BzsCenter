@page "/admin/roles"
@rendermode InteractiveServer
@using BzsOIDC.Idp.Services.Identity
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject IRoleManagementService RoleManagementService
@inject IPermissionCatalogService PermissionCatalogService
@inject IStringLocalizer<RoleManagement> L
@inject NavigationManager NavigationManager
@layout BzsOIDC.Idp.Client.Components.Layout.MainLayout

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_hasAccess)
{
    <div class="admin-loading-shell">
        <div class="admin-loading-card">
            <span class="admin-loading-kicker">@L["AdminArea"]</span>
            <h1>@L["CheckingAccess"]</h1>
            <p>@L["CheckingAccessLead"]</p>
        </div>
    </div>
}
else
{
    <section class="admin-page-shell">
        <header class="admin-hero">
            <div>
                <p class="admin-breadcrumb">@L["Overview"] &gt; @L["Identity"]</p>
                <h1>@L["PageTitle"]</h1>
                <p>@L["HeroLead"]</p>
            </div>
            <div class="admin-hero-actions">
                <button type="button" class="admin-primary-button" @onclick="CreateRoleAsync" disabled="@_isBusy">
                    @L["CreateRole"]
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="admin-feedback @(_statusIsError ? "is-error" : "is-success")" role="status" aria-live="polite">
                @_statusMessage
            </div>
        }

        <div class="admin-overview-grid">
            <section class="admin-overview-card">
                <header class="admin-overview-card-header">
                    <div>
                        <h2>@L["RoleOverview"]</h2>
                        <p>@L["RoleOverviewLead"]</p>
                    </div>
                </header>
                <div class="admin-overview-stats">
                    <span class="admin-user-meta">@L["RoleCount", _roles.Count]</span>
                    <span class="admin-user-meta">@L["ProtectedRoleCount", _roles.Count(static role => role.IsProtected)]</span>
                    <span class="admin-user-meta">@L["PermissionCount", SelectedRole?.PermissionCount ?? 0]</span>
                </div>
            </section>
        </div>

        <div class="admin-grid-toolbar">
            <div class="admin-search-stack">
                <div class="admin-search-icon-field">
                    <input id="role-search"
                           class="neo-input admin-search-input"
                           type="search"
                           placeholder="@L["SearchPlaceholder"]"
                           value="@_roleSearchTerm"
                           @oninput="HandleRoleSearchInput"
                           autocomplete="off"
                           aria-label="@L["Search"]" />
                </div>
                <span class="admin-grid-summary">@L["SearchResultSummary", FilteredRoles.Count]</span>
            </div>
            <div class="admin-grid-toolbar-actions">
                <button type="button" class="admin-ghost-button admin-toolbar-button" @onclick="LoadAsync" disabled="@_isBusy">
                    @L["Refresh"]
                </button>
            </div>
        </div>

        <div class="admin-permission-center">
            <div class="admin-permission-column admin-permission-column-primary">
                <section class="admin-overview-card admin-permission-panel">
                    <header class="admin-overview-card-header">
                        <div>
                            <h2>@L["Roles"]</h2>
                            <p>@L["RolesLead"]</p>
                        </div>
                    </header>

                    <NeoField Label="@L["RoleName"]" ForId="new-role-name" Hint="@L["CreateRoleHint"]">
                        <input id="new-role-name"
                               class="neo-input"
                               value="@_newRoleName"
                               @oninput="args => _newRoleName = args.Value?.ToString() ?? string.Empty" />
                    </NeoField>

                    <div class="admin-topology-list">
                        @foreach (var role in FilteredRoles)
                        {
                            <button type="button"
                                    class="admin-topology-row admin-topology-button @(IsSelectedRole(role) ? "is-active" : string.Empty)"
                                    @onclick="() => SelectRoleAsync(role.Id)">
                                <strong>@role.Name</strong>
                                <span class="admin-user-meta">@L["PermissionCount", role.PermissionCount]</span>
                                @if (role.IsProtected)
                                {
                                    <span class="admin-token">@L["Protected"]</span>
                                }
                            </button>
                        }
                    </div>
                </section>
            </div>

            <div class="admin-permission-column admin-permission-column-secondary">
                <section class="admin-overview-card admin-permission-panel">
                    <header class="admin-overview-card-header">
                        <div>
                            <h2>@L["RoleDetails"]</h2>
                        </div>
                    </header>

                    @if (SelectedRole is null)
                    {
                        <p class="admin-user-meta">@L["SelectRolePrompt"]</p>
                    }
                    else
                    {
                        <NeoField Label="@L["RoleName"]" ForId="selected-role-name" Hint="@(SelectedRole.IsProtected ? L["ProtectedRoleHint"] : L["RenameRoleHint"])">
                            <input id="selected-role-name"
                                   class="neo-input"
                                   value="@_selectedRoleName"
                                   disabled="@SelectedRole.IsProtected"
                                   @oninput="args => _selectedRoleName = args.Value?.ToString() ?? string.Empty" />
                        </NeoField>

                        <div class="admin-grid-toolbar-actions">
                            <button type="button" class="admin-secondary-button" @onclick="RenameRoleAsync" disabled="@(_isBusy || SelectedRole.IsProtected)">
                                @L["RenameRole"]
                            </button>
                            <button type="button" class="admin-ghost-button admin-toolbar-button danger" @onclick="DeleteRoleAsync" disabled="@(_isBusy || SelectedRole.IsProtected)">
                                @L["DeleteRole"]
                            </button>
                        </div>
                    }
                </section>

                <section class="admin-overview-card admin-permission-panel">
                    <header class="admin-overview-card-header">
                        <div>
                            <h2>@L["Permissions"]</h2>
                            <p>@L["PermissionsLead"]</p>
                        </div>
                    </header>

                    @if (SelectedRole is null)
                    {
                        <p class="admin-user-meta">@L["SelectRolePrompt"]</p>
                    }
                    else
                    {
                        <div class="admin-search-icon-field">
                            <input id="role-permission-search"
                                   class="neo-input admin-search-input"
                                   type="search"
                                   placeholder="@L["PermissionSearchPlaceholder"]"
                                   value="@_permissionSearchTerm"
                                   @oninput="HandlePermissionSearchInput"
                                   autocomplete="off"
                                   aria-label="@L["Search"]" />
                        </div>

                        <div class="admin-topology-list">
                            @foreach (var resource in FilteredResources)
                            {
                                <article class="admin-topology-row">
                                    <strong>@resource.DisplayName</strong>
                                    <span class="admin-user-meta">@resource.Key</span>
                                    <div class="admin-token-list">
                                        @foreach (var permission in resource.Permissions.OrderBy(static permission => permission.Name, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <label class="admin-token">
                                                <input type="checkbox"
                                                       checked="@_selectedPermissions.Contains(permission.Name)"
                                                       @onchange="args => TogglePermission(permission.Name, IsChecked(args.Value))" />
                                                @permission.Name
                                            </label>
                                        }
                                    </div>
                                </article>
                            }
                        </div>

                        <button type="button" class="admin-secondary-button" @onclick="SavePermissionsAsync" disabled="@_isBusy">
                            @L["SavePermissions"]
                        </button>
                    }
                </section>
            </div>
        </div>
    </section>
}

@code {
    private readonly List<RoleResponse> _roles = [];
    private readonly List<ProtectedResourceResponse> _resources = [];
    private readonly HashSet<string> _selectedPermissions = new(StringComparer.OrdinalIgnoreCase);
    private Guid? _selectedRoleId;
    private string _roleSearchTerm = string.Empty;
    private string _permissionSearchTerm = string.Empty;
    private string _newRoleName = string.Empty;
    private string _selectedRoleName = string.Empty;
    private string? _statusMessage;
    private bool _hasAccess;
    private bool _isBusy;
    private bool _statusIsError;

    private RoleResponse? SelectedRole => _roles.FirstOrDefault(role => role.Id == _selectedRoleId);

    private IReadOnlyList<RoleResponse> FilteredRoles => string.IsNullOrWhiteSpace(_roleSearchTerm)
        ? _roles
        : _roles.Where(role => role.Name.Contains(_roleSearchTerm, StringComparison.OrdinalIgnoreCase)).ToArray();

    private IReadOnlyList<ProtectedResourceResponse> FilteredResources => string.IsNullOrWhiteSpace(_permissionSearchTerm)
        ? _resources
        : _resources
            .Select(resource => resource with
            {
                Permissions = resource.Permissions
                    .Where(permission =>
                        permission.Name.Contains(_permissionSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                        permission.DisplayName.Contains(_permissionSearchTerm, StringComparison.OrdinalIgnoreCase))
                    .ToArray(),
            })
            .Where(resource => resource.Permissions.Length > 0)
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        if (!EnsureAdminAccess())
        {
            return;
        }

        await LoadAsync();
    }

    private bool EnsureAdminAccess()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            var loginPath = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["returnUrl"] = "/admin/roles",
            });

            NavigationManager.NavigateTo(loginPath, forceLoad: true);
            return false;
        }

        if (!user.IsInRole(IdentitySeedConstants.AdminRoleName))
        {
            NavigationManager.NavigateTo("/account/denied", forceLoad: true);
            return false;
        }

        _hasAccess = true;
        return true;
    }

    private async Task LoadAsync()
    {
        _isBusy = true;
        try
        {
            _roles.Clear();
            _roles.AddRange(await RoleManagementService.GetAllAsync());
            _resources.Clear();
            _resources.AddRange(await PermissionCatalogService.GetResourcesAsync());
            _selectedRoleId ??= _roles.FirstOrDefault()?.Id;
            await LoadSelectedRoleAsync();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task LoadSelectedRoleAsync()
    {
        if (_selectedRoleId is null)
        {
            _selectedRoleName = string.Empty;
            _selectedPermissions.Clear();
            return;
        }

        var role = await RoleManagementService.GetByIdAsync(_selectedRoleId.Value);
        if (role is null)
        {
            _selectedRoleId = _roles.FirstOrDefault()?.Id;
            role = _selectedRoleId is null ? null : await RoleManagementService.GetByIdAsync(_selectedRoleId.Value);
        }

        _selectedRoleName = role?.Name ?? string.Empty;
        _selectedPermissions.Clear();
        foreach (var permission in role?.Permissions ?? [])
        {
            _selectedPermissions.Add(permission);
        }
    }

    private async Task SelectRoleAsync(Guid roleId)
    {
        _selectedRoleId = roleId;
        await LoadSelectedRoleAsync();
    }

    private async Task CreateRoleAsync()
    {
        var result = await RoleManagementService.CreateAsync(new RoleUpsertRequest { Name = _newRoleName });
        await ApplyRoleResultAsync(result, L["RoleCreated"].Value);
        if (result.Status == RoleManagementCommandStatus.Success)
        {
            _newRoleName = string.Empty;
            _selectedRoleId = result.Value!.Id;
        }
    }

    private async Task RenameRoleAsync()
    {
        if (_selectedRoleId is null)
        {
            return;
        }

        var result = await RoleManagementService.UpdateAsync(_selectedRoleId.Value, new RoleUpsertRequest { Name = _selectedRoleName });
        await ApplyRoleResultAsync(result, L["RoleRenamed"].Value);
    }

    private async Task DeleteRoleAsync()
    {
        if (_selectedRoleId is null)
        {
            return;
        }

        var result = await RoleManagementService.DeleteAsync(_selectedRoleId.Value);
        await ApplyRoleResultAsync(result, L["RoleDeleted"].Value);
        if (result.Status == RoleManagementCommandStatus.Success)
        {
            _selectedRoleId = null;
        }
    }

    private async Task SavePermissionsAsync()
    {
        if (_selectedRoleId is null)
        {
            return;
        }

        var result = await RoleManagementService.SyncPermissionsAsync(_selectedRoleId.Value, _selectedPermissions);
        _statusIsError = result.Status != RoleManagementCommandStatus.Success;
        _statusMessage = result.Status == RoleManagementCommandStatus.Success
            ? L["PermissionsSaved"].Value
            : string.Join(Environment.NewLine, result.Errors);
        await LoadAsync();
    }

    private async Task ApplyRoleResultAsync(RoleManagementCommandResult<RoleResponse> result, string successMessage)
    {
        _statusIsError = result.Status != RoleManagementCommandStatus.Success;
        _statusMessage = result.Status == RoleManagementCommandStatus.Success
            ? successMessage
            : string.Join(Environment.NewLine, result.Errors);
        await LoadAsync();
    }

    private void TogglePermission(string permissionName, bool assigned)
    {
        if (assigned)
        {
            _selectedPermissions.Add(permissionName);
        }
        else
        {
            _selectedPermissions.Remove(permissionName);
        }
    }

    private static bool IsChecked(object? value)
    {
        return value switch
        {
            bool isChecked => isChecked,
            string stringValue => string.Equals(stringValue, bool.TrueString, StringComparison.OrdinalIgnoreCase) ||
                                  string.Equals(stringValue, "on", StringComparison.OrdinalIgnoreCase),
            _ => false,
        };
    }

    private bool IsSelectedRole(RoleResponse role)
    {
        return role.Id == _selectedRoleId;
    }

    private void HandleRoleSearchInput(ChangeEventArgs args)
    {
        _roleSearchTerm = args.Value?.ToString() ?? string.Empty;
    }

    private void HandlePermissionSearchInput(ChangeEventArgs args)
    {
        _permissionSearchTerm = args.Value?.ToString() ?? string.Empty;
    }
}

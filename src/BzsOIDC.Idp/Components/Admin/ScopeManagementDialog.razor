@using BzsOIDC.Idp.Services.Oidc
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ScopeManagement> L

<AdminDialogShell IsOpen="@IsOpen"
                  IsBusy="@IsBusy"
                  Title="@DialogTitle"
                  Lead="@DialogLead"
                  CloseLabel="@L["Close"]"
                  InitialFocusSelector="@InitialFocusSelector"
                  OnClose="OnClose">
    <ChildContent>
        @if (FormErrors.Count > 0)
        {
            <div class="admin-feedback is-error">
                <strong>@L["CouldNotSaveScope"]</strong>
                <ul>
                    @foreach (var error in FormErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <div class="admin-form-grid">
            <NeoField Label="@L["ScopeName"]" ForId="editor-scope-name" Hint="@L["ScopeNameHelp"]">
                <input id="editor-scope-name"
                       class="neo-input"
                       type="text"
                       value="@Name"
                       @oninput="HandleNameInput"
                       disabled="@IsEditing"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false" />
            </NeoField>

            <NeoField Label="@L["DisplayName"]" ForId="editor-scope-display-name">
                <input id="editor-scope-display-name"
                       class="neo-input"
                       type="text"
                       value="@DisplayName"
                       @oninput="HandleDisplayNameInput"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false" />
            </NeoField>

            <NeoField Label="@L["Description"]" ForId="editor-scope-description">
                <textarea id="editor-scope-description"
                          class="neo-textarea"
                          rows="3"
                          value="@Description"
                          @oninput="HandleDescriptionInput"
                          autocomplete="off"
                          autocapitalize="off"
                          autocorrect="off"
                          spellcheck="false"></textarea>
            </NeoField>

            <NeoField Label="@L["Resources"]" ForId="editor-scope-resources" Hint="@L["ResourcesHelp"]">
                <textarea id="editor-scope-resources"
                          class="neo-textarea"
                          rows="4"
                          value="@ResourcesText"
                          @oninput="HandleResourcesInput"
                          placeholder="@L["ResourcesPlaceholder"]"
                          autocomplete="off"
                          autocapitalize="off"
                          autocorrect="off"
                          spellcheck="false"></textarea>
            </NeoField>
        </div>
    </ChildContent>

    <Actions>
        <button type="button" class="admin-ghost-button" @onclick="OnReset" disabled="@IsBusy">
            @L["Reset"]
        </button>
        <button type="button" class="admin-primary-button" @onclick="OnSave" disabled="@IsBusy">
            @(IsBusy ? L["Saving"] : IsEditing ? L["SaveChanges"] : L["CreateScope"])
        </button>
    </Actions>
</AdminDialogShell>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> NameChanged { get; set; }
    [Parameter] public string DisplayName { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> DisplayNameChanged { get; set; }
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> DescriptionChanged { get; set; }
    [Parameter] public string ResourcesText { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ResourcesTextChanged { get; set; }
    [Parameter] public IReadOnlyList<string> FormErrors { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private string DialogLead => IsEditing ? L["EditScopeLead"] : L["CreateScopeLead"];
    private string DialogTitle => IsEditing ? L["EditScope"] : L["CreateScope"];
    private string InitialFocusSelector => IsEditing ? "#editor-scope-display-name" : "#editor-scope-name";

    private Task HandleNameInput(ChangeEventArgs args) => NameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    private Task HandleDisplayNameInput(ChangeEventArgs args) => DisplayNameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    private Task HandleDescriptionInput(ChangeEventArgs args) => DescriptionChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    private Task HandleResourcesInput(ChangeEventArgs args) => ResourcesTextChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}

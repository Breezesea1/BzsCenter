@page "/login"
@rendermode InteractiveServer
@attribute [ExcludeFromInteractiveRouting]
@layout BzsOIDC.Idp.Components.Auth.AuthLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@using System.Globalization
@using BzsOIDC.Idp.Components.Auth.Shared
@using BzsOIDC.Idp.Services.Identity
@inject IStringLocalizer<Login> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IExternalLoginProviderStore ExternalLoginProviderStore

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!_isRedirectingAuthenticatedUser)
{
    <div class="login-page">
        <LoginHero BrandName="OIDC"
                   BrandImageSrc="/oidc-brand.jpg"
                   PrivacyPolicyText='@L["PrivacyPolicy"]'
                   TermsOfServiceText='@L["TermsOfService"]'
                   UserNameInputId="username"
                   PasswordInputId="password" />

        <section class="login-panel">
            <div class="login-panel-top">
                <div class="mobile-brand">
                    <div class="brand-icon" aria-hidden="true">
                        <img src="/oidc-brand.jpg" alt="" width="32" height="32" />
                    </div>
                    <span class="brand-name">OIDC</span>
                </div>
                <AuthPreferences CurrentCulture="@CurrentCultureName" CurrentTheme="@CurrentThemeName"/>
            </div>
            <div class="login-card">

                <header class="login-header">
                    <h1>@L["WelcomeBack"]</h1>
                    <p>@L["EnterDetails"]</p>
                </header>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="login-error" role="alert">@ErrorMessage</div>
                }

                <form method="post" action="@BuildLoginAction()" class="login-form" autocomplete="off">
                    <AntiforgeryToken/>
                    <NeoField Class="field" Label="@L["UserNameLabel"]" ForId="username">
                        <input id="username"
                               class="neo-input"
                               name="UserName"
                               type="text"
                               placeholder="@L["UserNamePlaceholder"]"
                               autocomplete="off"
                               autocapitalize="off"
                               autocorrect="off"
                               spellcheck="false"
                               required/>
                    </NeoField>

                    <NeoField Class="field" Label="@L["PasswordLabel"]" ForId="password">
                        <div class="password-wrap">
                            <input id="password"
                                   class="neo-input"
                                   name="Password"
                                   type="@(_showPassword ? "text" : "password")"
                                   placeholder="@L["PasswordPlaceholder"]"
                                   autocomplete="new-password"
                                   autocapitalize="off"
                                   autocorrect="off"
                                   spellcheck="false"
                                   required/>
                            <button class="password-toggle"
                                    type="button"
                                    @onclick="TogglePassword"
                                    aria-pressed="@_showPassword.ToString().ToLowerInvariant()"
                                    aria-label="@L["TogglePassword"]">
                                @if (_showPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 3l18 18" fill="none" stroke="currentColor" stroke-width="2"
                                              stroke-linecap="round"/>
                                        <path d="M10.58 10.58a2 2 0 0 0 2.83 2.83" fill="none" stroke="currentColor"
                                              stroke-width="2" stroke-linecap="round"/>
                                        <path
                                            d="M9.88 5.09A10.94 10.94 0 0 1 12 4c5 0 9.27 3.11 11 8a11.85 11.85 0 0 1-4.29 5.54"
                                            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round"/>
                                        <path d="M6.61 6.61A11.84 11.84 0 0 0 1 12a11.82 11.82 0 0 0 6.17 6.61" fill="none"
                                              stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                              stroke-linejoin="round"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" fill="none"
                                              stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                              stroke-linejoin="round"/>
                                        <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </NeoField>

                    <div class="meta-row">
                        <label class="remember neo-check-field">
                            <input class="neo-checkbox" type="checkbox" name="RememberMe" value="true"/>
                            <span>@L["Remember30Days"]</span>
                        </label>
                        <a href="#">@L["ForgotPassword"]</a>
                    </div>

                    <button type="submit" class="btn-primary btn-slide">
                        <span class="label-static">@L["LoginButton"]</span>
                        <span class="label-hover">
                            <span>@L["LoginButton"]</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2"
                                      stroke-linecap="round"/>
                                <path d="m12 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                </form>

                @if (_externalLoginProviders.Count > 0)
                {
                    <div class="social-login">
                        @foreach (var provider in _externalLoginProviders)
                        {
                            <form method="post" action="@BuildExternalLoginAction(provider.RouteSegment)" autocomplete="off">
                                <AntiforgeryToken/>
                                <button type="submit" class="btn-primary btn-slide">
                                    <span class="label-static">
                                        @RenderProviderIcon(provider.Scheme)
                                        @L["LoginWithExternalProvider", provider.DisplayName]
                                    </span>
                                    <span class="label-hover">
                                        @RenderProviderIcon(provider.Scheme)
                                        <span>@L["LoginWithExternalProvider", provider.DisplayName]</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2"
                                                  stroke-linecap="round"/>
                                            <path d="m12 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2"
                                                  stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                </button>
                            </form>
                        }
                    </div>
                }

                <p class="signup-tip">
                    @L["NoAccount"]
                    <a href="@BuildRegisterHref()">@L["SignUp"]</a>
                </p>
            </div>
        </section>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery] public string? Error { get; set; }

    private bool _isRedirectingAuthenticatedUser;
    private bool _showPassword;
    private IReadOnlyList<ExternalLoginProvider> _externalLoginProviders = [];
    private string CurrentCultureName =>
        CultureInfo.CurrentUICulture.Name;

    private string CurrentThemeName =>
        "system";

    private string? ErrorMessage => Error switch
    {
        "invalid_credentials" => L["ErrorInvalidCredentials"].Value,
        "validation" => L["ErrorValidation"].Value,
        "external_login_failed" => L["ErrorExternalLoginFailed"].Value,
        "external_login_expired" => L["ErrorExternalLoginExpired"].Value,
        "external_login_access_denied" => L["ErrorExternalLoginAccessDenied"].Value,
        _ => null,
    };

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    protected override async Task OnInitializedAsync()
    {
        _externalLoginProviders = ExternalLoginProviderStore.GetEnabledProviders();
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authenticationState.User.Identity?.IsAuthenticated == true)
        {
            _isRedirectingAuthenticatedUser = true;
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
    }

    private string BuildLoginAction()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/account/login";
        }

        return QueryHelpers.AddQueryString("/account/login", new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }

    private string BuildExternalLoginAction(string routeSegment)
    {
        var path = $"/account/external-login/{Uri.EscapeDataString(routeSegment)}";
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return path;
        }

        return QueryHelpers.AddQueryString(path, new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }

    private string BuildRegisterHref()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/register";
        }

        return QueryHelpers.AddQueryString("/register", new Dictionary<string, string?>
        {
            ["returnUrl"] = ReturnUrl,
        });
    }

    private RenderFragment RenderProviderIcon(string scheme) => builder =>
    {
        if (!string.Equals(scheme, ExternalLoginProvider.GitHubScheme, StringComparison.Ordinal))
        {
            return;
        }

        builder.AddMarkupContent(0, "<svg class=\"provider-icon\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\"><path fill=\"currentColor\" d=\"M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.24.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.18 1.77 1.18 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.72-1.55-2.56-.29-5.25-1.28-5.25-5.72 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a10.88 10.88 0 0 1 5.78 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.24 2.75.12 3.04.74.8 1.18 1.82 1.18 3.08 0 4.45-2.69 5.42-5.26 5.7.41.36.77 1.05.77 2.13 0 1.54-.01 2.77-.01 3.15 0 .31.2.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z\"/></svg>");
    };

}

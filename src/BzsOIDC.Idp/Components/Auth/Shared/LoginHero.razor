@implements IAsyncDisposable
@using BzsOIDC.Idp.Client.Infra.Blazor
@inject IJSRuntime JS

<section class="login-hero" aria-hidden="true">
    <div class="login-brand">
        <div class="brand-icon">
            @if (!string.IsNullOrWhiteSpace(BrandImageSrc))
            {
                <img src="@BrandImageSrc" alt="" />
            }
            else
            {
                @BrandIconText
            }
        </div>
        <span class="brand-name">@BrandName</span>
    </div>

    <div class="hero-stage">
        <div class="hero-art"
             @ref="_heroArtRef"
             data-username-input-id="@UserNameInputId"
             data-password-input-id="@PasswordInputId">
            <div class="character purple">
                <div class="eyes">
                    <span class="eye"><i class="pupil"></i></span>
                    <span class="eye"><i class="pupil"></i></span>
                </div>
            </div>
            <div class="character charcoal">
                <div class="eyes">
                    <span class="eye"><i class="pupil"></i></span>
                    <span class="eye"><i class="pupil"></i></span>
                </div>
            </div>
            <div class="character orange">
                <div class="eyes solid">
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            </div>
            <div class="character yellow">
                <div class="eyes solid">
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
                <div class="mouth"></div>
            </div>
        </div>
    </div>

    <div class="hero-links">
        <a href="@PrivacyPolicyHref">@PrivacyPolicyText</a>
        <a href="@TermsOfServiceHref">@TermsOfServiceText</a>
    </div>
</section>

@code {
    [Parameter] public string BrandIconText { get; set; } = "B";
    [Parameter] public string? BrandImageSrc { get; set; }
    [Parameter] public string BrandName { get; set; } = string.Empty;
    [Parameter] public string PrivacyPolicyHref { get; set; } = "#";
    [Parameter] public string PrivacyPolicyText { get; set; } = string.Empty;
    [Parameter] public string TermsOfServiceHref { get; set; } = "#";
    [Parameter] public string TermsOfServiceText { get; set; } = string.Empty;
    [Parameter] public string UserNameInputId { get; set; } = "username";
    [Parameter] public string PasswordInputId { get; set; } = "password";

    private ElementReference _heroArtRef;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Auth/Shared/LoginHero.razor.js");
        await _module.InvokeVoidAsync("initHeroTracking", _heroArtRef);
    }

    public async ValueTask DisposeAsync()
    {
        await BlazorUtils.DisposeJsModuleAsync(async () =>
        {
            if (_module is null)
            {
                return;
            }

            await _module.InvokeVoidAsync("disposeHeroTracking", _heroArtRef);
            await _module.DisposeAsync();
            _module = null;
        });
    }
}

<div class="neo-panel @ToneClass @Class">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description))
    {
        <div class="neo-panel__header">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <strong class="neo-panel__title">@Title</strong>
            }

            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="neo-panel__description">@Description</p>
            }
        </div>
    }

    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string Tone { get; set; } = "soft";

    private string ToneClass => Tone.Equals("raised", StringComparison.OrdinalIgnoreCase)
        ? "neo-panel--raised"
        : "neo-panel--soft";
}

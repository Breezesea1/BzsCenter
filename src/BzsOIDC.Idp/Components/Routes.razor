@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(App).Assembly"
            AdditionalAssemblies="[typeof(BzsOIDC.Idp.Client._Imports).Assembly]"
            NotFoundPage="typeof(BzsOIDC.Idp.Client.Components.Pages.NotFound)">
        <Found Context="routeData">
            <CascadingValue Value="routeData">
                <RouteView RouteData="routeData" DefaultLayout="typeof(BzsOIDC.Idp.Client.Components.Layout.MainLayout)"/>
                <FocusOnNavigate RouteData="routeData" Selector="h1"/>
            </CascadingValue>
        </Found>
    </Router>
</CascadingAuthenticationState>

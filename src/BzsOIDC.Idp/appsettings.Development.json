{
  "IdpIssuer": "https://localhost:5001",
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownIpNetworks": []
  },
  "DataProtection": {
    "ApplicationName": "BzsOIDC.Idp.Dev",
    "StorageDirectory": "DevDataProtectionKeys",
    "KeyLifetimeDays": 365
  },
  "Oidc": {
    "SigninCertificatePath": [],
    "SigninCertificatePassword": [],
    "EncryptionCertificatePath": [],
    "EncryptionCertificatePassword": [],
    "AccessTokenLifetimeMinutes": 45,
    "RefreshTokenLifetimeDays": 7,
    "DisableAccessTokenEncryption": true
  },
  "Identity": {
    "Admin": {
      "UserName": "",
      "Password": ""
    },
    "InitialRoles": [
      "user"
    ],
    "RolePermissions": {
      "user": [
        "users.read.self"
      ]
    },
    "PermissionCatalog": [
      {
        "ResourceKey": "api",
        "DisplayName": "BzsOIDC Admin API",
        "Permissions": [
          {
            "Name": "users.read.self",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "users.read.all",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "users.write",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "roles.read",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "roles.write",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "permissions.read",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "permissions.write",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "clients.read",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "clients.write",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "scopes.read",
            "ReleaseScopes": [
              "api"
            ]
          },
          {
            "Name": "scopes.write",
            "ReleaseScopes": [
              "api"
            ]
          }
        ]
      }
    ],
    "AdditionalScopes": [
      "api"
    ]
  },
  "PermissionPolicy": {
    "PolicyPrefix": "perm:"
  },
  "Authentication": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-github"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

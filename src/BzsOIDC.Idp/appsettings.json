{
  "IdpIssuer": "https://idp.example.com",
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownIpNetworks": []
  },
  "DataProtection": {
    "ApplicationName": "BzsOIDC.Idp",
    "StorageDirectory": "/var/lib/bzsoidc/idp-dpkeys",
    "KeyLifetimeDays": 90
  },
  "Oidc": {
    "SigninCertificatePath": [],
    "SigninCertificatePassword": [],
    "EncryptionCertificatePath": [],
    "EncryptionCertificatePassword": [],
    "AccessTokenLifetimeMinutes": 45,
    "RefreshTokenLifetimeDays": 7,
    "DisableAccessTokenEncryption": true
  },
  "Identity": {
    "Admin": {
      "UserName": "",
      "Password": ""
    },
    "InitialRoles": [
      "user"
    ],
    "RolePermissions": {
      "user": [
        "users.read.self"
      ]
    },
    "PermissionScopes": {
      "users.read.self": [
        "api"
      ],
      "users.read.all": [
        "api"
      ],
      "users.write": [
        "api"
      ],
      "roles.read": [
        "api"
      ],
      "roles.write": [
        "api"
      ],
      "clients.read": [
        "api"
      ],
      "clients.write": [
        "api"
      ]
    },
    "AdditionalScopes": [
      "api"
    ]
  },
  "PermissionPolicy": {
    "PolicyPrefix": "perm:"
  },
  "Authentication": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-github"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
